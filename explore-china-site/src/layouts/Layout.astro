---
const { title = 'Exploration & Travel Club' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Student-led travel programs by Exploration & Travel Club" />
    <title>{title}</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Noto+Sans+SC:wght@400;500;700;800&display=swap');

      :root {
        --bg: #fffdf8;
        --bg-soft: #f7f4ee;
        --card: #ffffff;
        --text: #161616;
        --muted: #5f5f5f;
        --line: #ece7dc;
        --blue: #2563eb;
        --violet: #7c3aed;
        --green: #22c55e;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        font-family: 'Manrope', 'Noto Sans SC', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        background: linear-gradient(180deg, #fffdf8 0%, #fffaf0 100%);
        color: var(--text);
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }

      .container { max-width: 1120px; margin: 0 auto; padding: 22px; }

      header {
        position: sticky;
        top: 0;
        z-index: 30;
        backdrop-filter: blur(10px);
        background: rgba(255, 253, 248, 0.86);
        border-bottom: 1px solid var(--line);
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 0;
      }

      .brand {
        font-weight: 800;
        letter-spacing: -0.02em;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .link {
        color: #2f2f2f;
        font-size: 14px;
        padding: 8px 10px;
        border-radius: 10px;
      }
      .link:hover { background: #f4efe4; }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 11px 16px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
      }

      .btn-primary {
        background: #111;
        color: #fff;
      }

      .btn-ghost {
        background: #fff;
        color: #222;
        border-color: #ddd5c7;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid #dfd6c7;
        background: #fff;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        color: #4a4a4a;
      }

      .section { margin-top: 18px; }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 18px;
      }

      .muted { color: var(--muted); }
      .grid { display: grid; gap: 14px; }

      h1, h2, h3 { letter-spacing: -0.03em; margin: 0 0 10px; }

      h1 { font-size: clamp(34px, 6vw, 72px); line-height: 0.98; }
      h2 { font-size: clamp(24px, 3vw, 36px); line-height: 1.08; }
      h3 { font-size: 20px; }

      .footer {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid var(--line);
        color: #777;
        font-size: 13px;
      }

      @media (max-width: 900px) {
        .nav-right .link { display: none; }
        .container { padding: 16px; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a class="brand" href="/">Exploration & Travel Club</a>
          <div class="nav-right">
            <a class="link" href="/trips/explore-china-2026-summer">Trip</a>
            <a class="link" href="/trips/explore-china-2026-summer#faq">FAQ</a>
            <a class="btn btn-primary" href="/trips/explore-china-2026-summer#register">Apply</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
      <div class="footer">© {new Date().getFullYear()} Exploration & Travel Club · Student Community</div>
    </main>
  </body>
</html>
