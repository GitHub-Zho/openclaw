---
import '../styles/global.css';
import Navbar from '../components/v1/Navbar.astro';
import Footer from '../components/v1/Footer.astro';

const { title = 'Explore China', isZh = false } = Astro.props;
---
<!doctype html>
<html lang={isZh ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={isZh ? '学生中国文化探索之旅' : 'Student-led China cultural travel program'} />
    <title>{title}</title>
  </head>
  <body>
    <Navbar isZh={isZh} />
    <main>
      <slot />
    </main>
    <Footer isZh={isZh} />
  </body>
</html>
