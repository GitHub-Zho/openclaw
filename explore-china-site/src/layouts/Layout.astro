---
const { title = 'Exploration & Travel Club' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Student-led travel programs by Exploration & Travel Club" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f6f5f1;
        --card: #ffffff;
        --text: #151515;
        --muted: #5f646a;
        --line: #e6e2d8;

        /* 8pt grid */
        --s-1: 4px;
        --s-2: 8px;
        --s-3: 12px;
        --s-4: 16px;
        --s-5: 20px;
        --s-6: 24px;
        --s-7: 32px;
        --s-8: 40px;

        /* Type scale */
        --label: 12px;
        --body: 16px;
        --body-sm: 14px;
        --h3: 22px;
        --h2: clamp(28px, 3.2vw, 40px);
        --h1: clamp(40px, 6vw, 76px);

        /* unified radius */
        --radius: 16px;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', 'Segoe UI', Roboto, Arial, sans-serif;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }

      .container { max-width: 1120px; margin: 0 auto; padding: var(--s-6); }
      .section { margin-top: var(--s-6); }
      .grid { display: grid; gap: var(--s-4); }
      .cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: var(--s-5);
        box-shadow: 0 1px 0 rgba(15,15,15,0.02);
      }

      .muted {
        color: var(--muted);
        font-size: var(--body);
        line-height: 1.6;
        font-weight: 450;
      }

      .label {
        font-size: var(--label);
        color: #6b6f75;
        letter-spacing: 0.01em;
        font-weight: 550;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 30;
        background: rgba(247, 247, 244, 0.88);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line);
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--s-3);
        padding: var(--s-3) 0;
      }

      .brand { font-weight: 680; letter-spacing: -0.02em; }
      .nav-right { display: flex; align-items: center; gap: var(--s-2); }

      .link {
        font-size: var(--body-sm);
        color: #2a2a2a;
        padding: var(--s-2) var(--s-3);
        border-radius: 10px;
      }
      .link:hover { background: #efefea; }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: var(--body-sm);
        font-weight: 600;
        border: 1px solid transparent;
        transition: 120ms ease;
      }

      .btn-primary {
        background: #161616;
        color: #fff;
      }
      .btn-primary:hover { background: #000; transform: translateY(-1px); }

      .btn-secondary {
        background: #fff;
        color: #111;
        border-color: #d7d7d0;
      }
      .btn-secondary:hover { background: #f8f8f5; }

      .pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: var(--label);
        border: 1px solid #dadad3;
        background: #fff;
        color: #555;
        font-weight: 550;
      }

      h1, h2, h3 {
        margin: 0 0 var(--s-3);
        letter-spacing: -0.03em;
        line-height: 1.04;
        font-weight: 680;
      }
      h1 { font-size: var(--h1); }
      h2 { font-size: var(--h2); }
      h3 { font-size: var(--h3); }

      p {
        margin: 0 0 var(--s-3);
        font-size: var(--body);
        line-height: 1.65;
      }

      .photo {
        height: 240px;
        width: 100%;
        object-fit: cover;
        border-radius: var(--radius);
        border: 1px solid var(--line);
        filter: saturate(0.88) contrast(0.96) brightness(1.02);
      }

      .footer {
        margin-top: var(--s-8);
        padding-top: var(--s-5);
        border-top: 1px solid var(--line);
        color: #777;
        font-size: 13px;
      }

      @media (max-width: 920px) {
        .container { padding: var(--s-4); }
        .nav-right .link { display: none; }
        .cols-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .cols-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      }
      @media (max-width: 640px) {
        .cols-4, .cols-3, .cols-2 { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a class="brand" href="/">Exploration & Travel Club</a>
          <div class="nav-right">
            <a class="link" href="/trips/explore-china-2026-summer">Trip</a>
            <a class="link" href="/handbook">Handbook</a>
            <a class="link" href="/zh/">中文</a>
            <a class="btn btn-primary" href="/trips/explore-china-2026-summer#register">Apply</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
      <div class="footer">© {new Date().getFullYear()} Exploration & Travel Club · Student Community</div>
    </main>
  </body>
</html>
