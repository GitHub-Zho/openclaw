---
const { title = 'Exploration & Travel Club' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Student-led travel programs by Exploration & Travel Club" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #080d1a;
        --panel: #10182d;
        --panel-2: #0d1427;
        --text: #edf2ff;
        --muted: #a9b6d3;
        --line: #243253;
        --accent: #8bd0ff;
        --accent-2: #9d8bff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        color: var(--text);
        background: radial-gradient(1200px 600px at 70% -10%, #182549 0%, transparent 55%), var(--bg);
      }
      a { color: var(--accent); text-decoration: none; }
      .container { max-width: 1120px; margin: 0 auto; padding: 24px; }
      .grid { display: grid; gap: 16px; }
      .card {
        background: linear-gradient(180deg, var(--panel) 0%, var(--panel-2) 100%);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 20px;
      }
      .muted { color: var(--muted); }
      .pill {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 6px 10px;
        border: 1px solid #30436e;
        background: #101a34;
        border-radius: 999px;
        color: #c6d5ff;
        font-size: 13px;
      }
      .btn {
        display: inline-block;
        background: linear-gradient(90deg, #2d7cff 0%, #6764ff 100%);
        border: none;
        color: white;
        padding: 11px 16px;
        border-radius: 10px;
        font-weight: 600;
      }
      .btn.ghost {
        background: transparent;
        border: 1px solid #3a4f80;
      }
      header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid #1d2848;
        backdrop-filter: blur(8px);
        background: #080d1acc;
      }
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 0;
      }
      .brand { color: #dbe7ff; font-weight: 700; }
      .nav-links { display: flex; gap: 14px; font-size: 14px; }
      footer { margin-top: 36px; border-top: 1px solid #1e2a49; padding-top: 20px; color: var(--muted); font-size: 14px; }
      @media (max-width: 820px) {
        .container { padding: 16px; }
        .nav-links { display: none; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a class="brand" href="/">Exploration & Travel Club</a>
          <div class="nav-links">
            <a href="/trips/explore-china-2026-summer">Current Trip</a>
            <a href="/trips/explore-china-2026-summer#faq">FAQ</a>
            <a href="/trips/explore-china-2026-summer#register">Registration</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
      <footer>
        <p>© {new Date().getFullYear()} Exploration & Travel Club · University student travel community</p>
      </footer>
    </main>
  </body>
</html>
