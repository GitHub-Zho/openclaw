---
const { title = 'Exploration & Travel Club' } = Astro.props;
const path = Astro.url.pathname;
const isZh = path.startsWith('/zh');
const switchHref = isZh ? path.replace(/^\/zh/, '') || '/' : `/zh${path === '/' ? '/' : path}`;
const navHome = isZh ? '/zh/' : '/';
const navTrip = isZh ? '/zh/trips/explore-china-2026-summer' : '/trips/explore-china-2026-summer';
const navHandbook = isZh ? '/zh/handbook' : '/handbook';
const navRegister = `${navTrip}#register`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Student-led travel programs by Exploration & Travel Club" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f6f5f1;
        --card: #ffffff;
        --text: #151515;
        --muted: #5f646a;
        --line: #e6e2d8;

        /* 8pt grid */
        --s-1: 4px;
        --s-2: 8px;
        --s-3: 12px;
        --s-4: 16px;
        --s-5: 20px;
        --s-6: 24px;
        --s-7: 32px;
        --s-8: 40px;

        /* Type scale */
        --label: 12px;
        --body: 16px;
        --body-sm: 14px;
        --h3: 22px;
        --h2: clamp(28px, 3.2vw, 40px);
        --h1: clamp(40px, 6vw, 76px);

        /* unified radius */
        --radius: 16px;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', 'Segoe UI', Roboto, Arial, sans-serif;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a { color: inherit; text-decoration: none; }
      .text-link {
        color: #0b4ea2;
        text-decoration: underline;
        text-underline-offset: 3px;
        font-weight: 600;
      }
      .section-title { text-align:center; margin-bottom: 10px; }
      .section-sub { text-align:center; max-width:720px; margin: 0 auto 14px; }
      img { max-width: 100%; display: block; }

      .container { max-width: 1120px; margin: 0 auto; padding: var(--s-6); }
      .section { margin-top: var(--s-6); }
      .grid { display: grid; gap: var(--s-4); }
      .cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: var(--s-5);
        box-shadow: 0 1px 0 rgba(15,15,15,0.02);
        transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
      }
      .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(22,22,22,0.08); border-color: #d8d3c7; }
      .tone-sand { background: linear-gradient(180deg, #fff6e9, #f6e8d2); border-color:#e5d2b1; }
      .tone-blue { background: linear-gradient(180deg, #ebf4ff, #d8eaff); border-color:#bdd7fa; }
      .tone-rose { background: linear-gradient(180deg, #ffeef0, #fddfe4); border-color:#efc1c9; }
      .tone-dark { background: linear-gradient(180deg, #111111, #262626); color: #f8f8f8; border-color: #3d3d3d; }
      .tone-dark .muted { color: #d0d0d0; }

      .muted {
        color: var(--muted);
        font-size: var(--body);
        line-height: 1.6;
        font-weight: 450;
      }

      .label {
        font-size: var(--label);
        color: #6b6f75;
        letter-spacing: 0.01em;
        font-weight: 550;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 30;
        background: rgba(247, 247, 244, 0.88);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line);
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--s-3);
        padding: var(--s-3) 0;
      }

      .brand { font-weight: 680; letter-spacing: -0.02em; }
      .nav-right { display: flex; align-items: center; gap: var(--s-2); }

      .link {
        font-size: var(--body-sm);
        color: #2a2a2a;
        padding: var(--s-2) var(--s-3);
        border-radius: 10px;
      }
      .link:hover { background: #efefea; }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: var(--body-sm);
        font-weight: 600;
        border: 1px solid transparent;
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
      }

      .btn-primary {
        background: #161616;
        color: #fff;
      }
      .btn-primary:hover { background: #000; transform: translateY(-1px); box-shadow: 0 10px 20px rgba(0,0,0,0.25); }

      .btn-secondary {
        background: #fff;
        color: #111;
        border-color: #d7d7d0;
      }
      .btn-secondary:hover { background: #f8f8f5; }
      .form-grid { display:grid; gap:12px; grid-template-columns:repeat(2,minmax(0,1fr)); }
      .field { display:flex; flex-direction:column; gap:6px; }
      .field label { font-size:13px; color:#525a62; font-weight:600; }
      .field input, .field select, .field textarea {
        border:1px solid #d8dce2; border-radius:12px; padding:11px 12px; font: inherit; background:#fff;
      }
      .field textarea { min-height:110px; resize:vertical; }

      .pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: var(--label);
        border: 1px solid #dadad3;
        background: #fff;
        color: #555;
        font-weight: 550;
      }

      h1, h2, h3 {
        margin: 0 0 var(--s-3);
        letter-spacing: -0.03em;
        line-height: 1.04;
        font-weight: 680;
      }
      h1 { font-size: var(--h1); }
      h2 { font-size: var(--h2); }
      h3 { font-size: var(--h3); }

      p {
        margin: 0 0 var(--s-3);
        font-size: var(--body);
        line-height: 1.65;
      }

      .photo {
        height: 240px;
        width: 100%;
        object-fit: cover;
        border-radius: var(--radius);
        border: 1px solid var(--line);
        filter: saturate(0.9) contrast(0.98) brightness(1.02);
      }
      .media-hero { height: min(52vh, 520px); }
      .media-wide { aspect-ratio: 16 / 9; height: auto; }
      .media-card { aspect-ratio: 4 / 3; height: auto; }
      .media-tall { aspect-ratio: 3 / 4; height: auto; }
      .carousel-head { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:10px; gap:10px; }
      .carousel-state { margin:0; font-size:13px; color:#46566b; font-weight:650; }
      .carousel { position: relative; overflow: hidden; border-radius: var(--radius); }
      .carousel-track { display:flex; transition: transform 420ms cubic-bezier(.22,.8,.3,1); }
      .carousel-slide { min-width: 100%; padding: 0; }
      .carousel-btn {
        position:absolute; top:50%; transform:translateY(-50%); z-index:2;
        width:38px; height:38px; border-radius:999px; border:1px solid #d2d7df;
        background:#fff; cursor:pointer; font-weight:700;
      }
      .carousel-btn.prev { left:10px; }
      .carousel-btn.next { right:10px; }
      .carousel-progress { width:100%; height:5px; border-radius:999px; overflow:hidden; background:#d5deea; margin:10px 0; }
      .carousel-progress span { display:block; height:100%; width:0; background:linear-gradient(90deg,#253b64,#5f84cb); transition: width 320ms ease; }
      .carousel-dots { display:flex; justify-content:center; gap:8px; margin-top:10px; }
      .carousel-dots button { width:9px; height:9px; border-radius:999px; border:none; background:#b8c0cb; cursor:pointer; transition:transform 180ms ease, background 180ms ease; }
      .carousel-dots button.active { background:#1d2530; transform:scale(1.2); }
      details summary { list-style: none; position: relative; padding-right: 22px; }
      details summary::after { content:'+'; position:absolute; right:4px; top:0; color:#6a7380; font-weight:700; }
      details[open] summary::after { content:'−'; }

      .footer {
        margin-top: var(--s-8);
        padding-top: var(--s-5);
        border-top: 1px solid var(--line);
        color: #777;
        font-size: 13px;
      }

      @media (max-width: 920px) {
        .container { padding: var(--s-4); }
        .nav-right .link { display: none; }
        .cols-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .cols-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      }
      @media (max-width: 640px) {
        .cols-4, .cols-3, .cols-2, .form-grid { grid-template-columns: 1fr; }
      }
      @media (prefers-reduced-motion: reduce) {
        .card, .btn, .motion-track { transition: none !important; animation: none !important; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a class="brand" href={navHome}>{isZh ? '探索中国 · 旅行社群' : 'Exploration & Travel Club'}</a>
          <div class="nav-right">
            <a class="link" href={navTrip}>{isZh ? '行程' : 'Trip'}</a>
            <a class="link" href={navHandbook}>{isZh ? '手册' : 'Handbook'}</a>
            <a class="btn btn-secondary" href={switchHref}>{isZh ? 'EN' : '中文'}</a>
            <a class="btn btn-primary" href={navRegister}>{isZh ? '报名' : 'Apply'}</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
      <div class="footer">© {new Date().getFullYear()} Exploration & Travel Club · Student Community</div>
    </main>
  </body>
</html>
