---
const {
  id = 'overview',
  badge,
  title,
  subtitle,
  image,
  imageAlt,
  stats,
  ctas,
  route,
  price,
  departs,
  asideLabel = 'Trip brief',
  asideTitle = 'Route & departure',
  asideRouteLabel = 'Route',
  asidePriceLabel = 'From',
  asideDepartsLabel = 'Departures',
  asideCtaLabel = 'Check seats',
} = Astro.props as {
  id?: string;
  badge: string;
  title: string;
  subtitle: string;
  image: string;
  imageAlt: string;
  stats: { label: string; value: string }[];
  ctas: { href: string; label: string; kind?: 'primary' | 'secondary' }[];
  route: string;
  price: string;
  departs: string;
  asideLabel?: string;
  asideTitle?: string;
  asideRouteLabel?: string;
  asidePriceLabel?: string;
  asideDepartsLabel?: string;
  asideCtaLabel?: string;
};
---
<section id={id} class="section hero-shell">
  <div class="hero-main">
    <img class="hero-bg" src={image} alt={imageAlt} loading="eager" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="pill">{badge}</p>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-sub">{subtitle}</p>
      <div class="hero-ctas">
        {ctas.map((c) => <a class={`btn ${c.kind === 'secondary' ? 'btn-secondary' : 'btn-primary'}`} href={c.href}>{c.label}</a>)}
      </div>
      <div class="hero-stats">
        {stats.map((s) => <article class="hero-stat"><p class="label">{s.label}</p><p>{s.value}</p></article>)}
      </div>
    </div>
  </div>

  <aside class="hero-aside card tone-sand">
    <p class="label">{asideLabel}</p>
    <h3>{asideTitle}</h3>
    <p class="muted"><strong>{asideRouteLabel}:</strong> {route}</p>
    <p class="muted"><strong>{asidePriceLabel}:</strong> {price}</p>
    <p class="muted"><strong>{asideDepartsLabel}:</strong> {departs}</p>
    <a class="btn btn-primary" href="#apply">{asideCtaLabel}</a>
  </aside>
</section>

<style>
  .hero-shell { display:grid; grid-template-columns: 1.8fr 1fr; gap: 16px; }
  .hero-main {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    min-height: clamp(380px, 62vh, 680px);
    display:flex;
    align-items:flex-end;
    border: 1px solid rgba(255,255,255,.25);
  }
  .hero-bg {
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    object-fit:cover;
    animation: kenburns 12s ease-in-out infinite alternate;
  }
  .hero-overlay {
    position:absolute;
    inset:0;
    background: linear-gradient(120deg, rgba(0,0,0,.62) 0%, rgba(0,0,0,.38) 42%, rgba(0,0,0,.16) 100%);
  }
  .hero-content {
    position:relative;
    z-index:1;
    color:#fff;
    padding: clamp(20px, 3.5vw, 38px);
    max-width: 920px;
  }
  .hero-title { margin: 12px 0; font-size: clamp(2.5rem, 8vw, 6rem); line-height: .96; letter-spacing: -.02em; }
  .hero-sub { max-width: 64ch; margin-bottom: 14px; color: rgba(255,255,255,.92); }
  .hero-ctas { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:14px; }
  .hero-stats { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 10px; max-width: 560px; }
  .hero-stat { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.22); border-radius: 12px; padding: 10px; }
  .hero-stat p { margin:0; color:#fff; }
  .hero-stat .label { color: #e8edf5; margin-bottom: 4px; }
  .hero-aside { display:flex; flex-direction:column; justify-content:center; }

  @keyframes kenburns {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }

  @media (max-width: 980px) {
    .hero-shell { grid-template-columns: 1fr; }
    .hero-main { min-height: 460px; }
  }
  @media (max-width: 640px) {
    .hero-stats { grid-template-columns: 1fr; }
    .hero-main { min-height: 390px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { animation: none; }
  }
</style>