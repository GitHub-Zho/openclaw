---
const {
  id = 'overview',
  badge,
  title,
  subtitle,
  image,
  imageAlt,
  stats,
  ctas,
  route,
  price,
  departs,
} = Astro.props as {
  id?: string;
  badge: string;
  title: string;
  subtitle: string;
  image: string;
  imageAlt: string;
  stats: { label: string; value: string }[];
  ctas: { href: string; label: string; kind?: 'primary' | 'secondary' }[];
  route: string;
  price: string;
  departs: string;
};
---
<section id={id} class="section hero-shell">
  <div class="hero-main card tone-dark">
    <div>
      <p class="pill">{badge}</p>
      <h1 class="hero-title">{title}</h1>
      <p class="muted hero-sub">{subtitle}</p>
      <div class="hero-ctas">
        {ctas.map((c) => <a class={`btn ${c.kind === 'secondary' ? 'btn-secondary' : 'btn-primary'}`} href={c.href}>{c.label}</a>)}
      </div>
      <div class="hero-stats">
        {stats.map((s) => <article class="hero-stat"><p class="label">{s.label}</p><p>{s.value}</p></article>)}
      </div>
    </div>
    <div class="hero-media-wrap">
      <img class="photo hero-media" src={image} alt={imageAlt} loading="lazy" />
    </div>
  </div>

  <aside class="hero-aside card tone-sand">
    <p class="label">Classic-tour structure</p>
    <h3>Route & departure brief</h3>
    <p class="muted"><strong>Route:</strong> {route}</p>
    <p class="muted"><strong>From:</strong> {price}</p>
    <p class="muted"><strong>Departures:</strong> {departs}</p>
    <a class="btn btn-primary" href="#apply">Check seats</a>
  </aside>
</section>

<style>
  .hero-shell { display:grid; grid-template-columns: 1.8fr 1fr; gap: 16px; }
  .hero-main { display:grid; grid-template-columns: 1.2fr 1fr; gap: 18px; align-items: stretch; }
  .hero-title { margin: 12px 0; font-size: clamp(34px, 4.8vw, 68px); }
  .hero-sub { max-width: 58ch; margin-bottom: 14px; }
  .hero-ctas { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:14px; }
  .hero-stats { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 10px; }
  .hero-stat { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); border-radius: 12px; padding: 10px; }
  .hero-stat p { margin:0; }
  .hero-stat .label { color: #d7dee8; margin-bottom: 4px; }
  .hero-media-wrap { display:flex; }
  .hero-media { width:100%; height:100%; min-height: 320px; object-fit: cover; }
  .hero-aside { display:flex; flex-direction:column; justify-content:center; }
  @media (max-width: 980px) {
    .hero-shell { grid-template-columns: 1fr; }
    .hero-main { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .hero-stats { grid-template-columns: 1fr; }
  }
</style>