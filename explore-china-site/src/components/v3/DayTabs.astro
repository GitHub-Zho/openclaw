---
interface Day { key:string; label:string; title:string; body:string; hotel:string; meals:string; transport:string }
const { id, title, days } = Astro.props as { id:string; title:string; days: Day[] };
---
<section class="section card tone-blue" id={id}>
  <h2 class="section-title">{title}</h2>
  <div style="display:flex; justify-content:center; gap:8px; flex-wrap:wrap; margin-bottom:10px;">
    {days.map((d, i) => <button class="btn btn-secondary js-day" data-group={id} data-day={d.key} style={i===0?'background:#111;color:#fff;border-color:#111':''}>{d.label}</button>)}
  </div>
  <article class="card" data-panel={id} style="max-width:920px; margin:0 auto; background:#fff;">
    <p class="pill" data-field="label">{days[0].label}</p>
    <h3 style="margin:10px 0 6px;" data-field="title">{days[0].title}</h3>
    <p class="muted" style="margin:0 0 10px;" data-field="body">{days[0].body}</p>
    <div class="grid cols-3">
      <div class="card" style="background:#fcfbf8;"><p class="label">Hotel</p><p style="margin:6px 0 0; font-weight:700;" data-field="hotel">{days[0].hotel}</p></div>
      <div class="card" style="background:#fcfbf8;"><p class="label">Meals</p><p style="margin:6px 0 0; font-weight:700;" data-field="meals">{days[0].meals}</p></div>
      <div class="card" style="background:#fcfbf8;"><p class="label">Transport</p><p style="margin:6px 0 0; font-weight:700;" data-field="transport">{days[0].transport}</p></div>
    </div>
  </article>
</section>

<script is:inline define:vars={{ id, days }}>
  (() => {
    const map = Object.fromEntries(days.map((d) => [d.key, d]));
    const panel = document.querySelector(`[data-panel="${id}"]`);
    const set = (k, v) => {
      const el = panel.querySelector(`[data-field="${k}"]`);
      if (el) el.textContent = v;
    };
    document.querySelectorAll(`.js-day[data-group="${id}"]`).forEach((btn) => {
      btn.addEventListener('click', () => {
        const d = map[btn.getAttribute('data-day')];
        if (!d) return;
        set('label', d.label); set('title', d.title); set('body', d.body); set('hotel', d.hotel); set('meals', d.meals); set('transport', d.transport);
        document.querySelectorAll(`.js-day[data-group="${id}"]`).forEach((x) => { x.style.background=''; x.style.color=''; x.style.borderColor=''; });
        btn.style.background='#111'; btn.style.color='#fff'; btn.style.borderColor='#111';
      });
    });
  })();
</script>
