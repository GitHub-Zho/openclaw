---
interface Pillar {
  label: string;
  title: string;
  detail: string;
}
interface Snapshot {
  label: string;
  value: string;
  note: string;
}
const { id='decision', title, subtitle, pillars, snapshots, checklistTitle, checklist } = Astro.props as {
  id?: string;
  title: string;
  subtitle: string;
  pillars: Pillar[];
  snapshots: Snapshot[];
  checklistTitle: string;
  checklist: string[];
};
---
<section id={id} class="section decision-shell">
  <article class="card tone-sand">
    <h2>{title}</h2>
    <p class="muted">{subtitle}</p>
    <div class="decision-pillars">
      {pillars.map((item) => (
        <article class="decision-pillar">
          <p class="label">{item.label}</p>
          <h3>{item.title}</h3>
          <p class="muted">{item.detail}</p>
        </article>
      ))}
    </div>
  </article>

  <article class="card">
    <h3>{checklistTitle}</h3>
    <ul class="decision-list muted">
      {checklist.map((item) => <li>{item}</li>)}
    </ul>
    <div class="decision-snapshots">
      {snapshots.map((item) => (
        <article>
          <p class="label">{item.label}</p>
          <p class="snapshot-value">{item.value}</p>
          <p class="muted">{item.note}</p>
        </article>
      ))}
    </div>
  </article>
</section>

<style>
  .decision-shell { display:grid; grid-template-columns: 1.3fr 1fr; gap: 16px; }
  .decision-pillars { display:grid; gap:10px; grid-template-columns: repeat(3,minmax(0,1fr)); }
  .decision-pillar { background:rgba(255,255,255,.72); border:1px solid #ead7b8; border-radius:12px; padding:12px; }
  .decision-pillar h3 { font-size: 20px; margin-bottom:8px; }
  .decision-list { margin: 0 0 14px; padding-left: 18px; }
  .decision-list li { margin-bottom: 8px; }
  .decision-snapshots { display:grid; gap:10px; grid-template-columns: repeat(2,minmax(0,1fr)); }
  .decision-snapshots article { border:1px solid #e3e5ea; border-radius:12px; padding:10px; background:#fafbfc; }
  .snapshot-value { margin:6px 0; font-size: 20px; font-weight: 700; }
  @media (max-width: 980px) {
    .decision-shell, .decision-pillars { grid-template-columns: 1fr; }
    .decision-snapshots { grid-template-columns: 1fr; }
  }
</style>
