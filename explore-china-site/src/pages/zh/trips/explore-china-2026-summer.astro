---
import Layout from '../../../layouts/Layout.astro';
import { cityVisuals, included, notIncluded, itinerary } from '../../../data/site';

const zhCityNames: Record<string, string> = { Shanghai: '上海', Suzhou: '苏州', Hangzhou: '杭州', Beijing: '北京' };
const zhFaq = [
  { q: '谁可以参加？', a: '当前主要面向学生群体，最终名额与资格规则将在报名开放前公布。' },
  { q: 'CAD $3,000 包含什么？', a: '主要覆盖核心住宿、境内交通、指定活动门票及组织支持；国际机票不包含。' },
  { q: '行程会不会太赶？', a: '节奏为“核心固定 + 弹性探索”模式，兼顾体验完整性与舒适度。' },
  { q: '饮食限制可以安排吗？', a: '可以尽量协调，请尽早告知；不同城市和餐厅可替代项会有差异。' },
  { q: '这次行程只是普通观光吗？', a: '不是。行程包含本地学生交流活动与文化社交环节，目标是让参与者在地标打卡之外建立真实的人际连接与文化理解。' },
];
---
<Layout title="探索中国 · 10天行程" lang="zh" alternateHref="/trips/explore-china-2026-summer" alternateLabel="EN">
  <section id="overview" class="section card tone-sand" style="padding:34px;">
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:12px; text-align:center;">探索中国 · 10天暑期行程</h1>
    <p class="muted section-sub" style="font-size:18px;">这是一条面向加拿大学生用户的中国深度线路：融合城市地标、本地文化、同龄社交交流与清晰可靠的组织支持。</p>
    <div class="grid cols-4" style="margin-top:14px;">
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">路线</p><p style="margin:6px 0 0; font-weight:680;">上海 → 苏州 → 杭州 → 北京</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">出发日期</p><p style="margin:6px 0 0; font-weight:680;">2026年7月（具体日期待确认）</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">报名截止</p><p style="margin:6px 0 0; font-weight:680;">2026年5月31日</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">团队规模</p><p style="margin:6px 0 0; font-weight:680;">最多 20 人</p></article>
    </div>
    <p class="muted" style="text-align:center; margin-top:10px;">联系邮箱：hello@explorationclub.ca</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; justify-content:center;"><a class="btn btn-primary" href="#register">报名入口</a><a class="btn btn-secondary" href="/zh/handbook">查看手册</a></div>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">信任与执行保障</h2>
    <div class="grid cols-4">
      <article class="card" style="background:#fff;"><p class="label">回复时效</p><p style="font-weight:700; margin:6px 0 0;">24小时内</p></article>
      <article class="card" style="background:#fff;"><p class="label">语言支持</p><p style="font-weight:700; margin:6px 0 0;">中英双语</p></article>
      <article class="card" style="background:#fff;"><p class="label">执行方式</p><p style="font-weight:700; margin:6px 0 0;">结构化 + 可控自由</p></article>
      <article class="card" style="background:#fff;"><p class="label">线索管理</p><p style="font-weight:700; margin:6px 0 0;">表单+邮件跟进</p></article>
    </div>
  </section>

  <section id="destinations" class="section grid cols-4">
    {cityVisuals.map((city) => (
      <figure style="margin:0;" class="card tone-blue"><img class="photo media-card" src={city.image} alt={city.alt} /><figcaption class="label" style="margin-top:8px; text-align:center;">{zhCityNames[city.city] ?? city.city}</figcaption></figure>
    ))}
  </section>

  <section class="section card tone-rose">
    <h2 class="section-title">城市亮点（结构占位）</h2>
    <div class="grid cols-2">
      {cityVisuals.map((city) => (
        <article class="card" style="background:#fff;">
          <h3>{zhCityNames[city.city] ?? city.city}</h3>
          <ul class="muted" style="line-height:1.8; padding-left:18px; margin:8px 0 0;">
            <li>亮点占位 01</li>
            <li>亮点占位 02</li>
            <li>亮点占位 03</li>
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section id="itinerary" class="section card">
    <h2 class="section-title">每日摘要</h2>
    <ul class="muted" style="line-height:1.9; margin:0; padding-left:18px;">
      <li>第1天 上海 — 抵达、入住、基础设置</li>
      <li>第2天 苏州 — 园林、运河、博物馆</li>
      <li>第3天 上海 — 豫园、外滩、老城</li>
      <li>第4天 上海 — 弹性探索日</li>
      <li>第5天 杭州 — 西湖、灵隐、龙井</li>
      <li>第6天 北京 — 转场与初览</li>
      <li>第7天 北京 — 长城</li>
      <li>第8天 北京 — 故宫 + 颐和园</li>
      <li>第9天 北京 — 学生交流 + 结营夜</li>
      <li>第10天 北京 — 离境</li>
    </ul>
  </section>

  <section class="section card tone-dark">
    <h2 class="section-title">详细行程</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px; background:#fff; color:#151515;"><p class="pill" style="margin-bottom:8px;">{d.day}</p><h3 style="margin-bottom:6px;">{zhCityNames[d.city] ?? d.city}</h3><p class="muted" style="margin:0;">{d.plan}</p></article>
      ))}
    </div>
  </section>

  <section class="section card tone-sand">
    <h2 class="section-title">价格与预订规则</h2>
    <div class="grid cols-3">
      <article class="card" style="background:#fff;"><h3>订金</h3><p class="muted" style="margin:0;">席位确认后支付 CAD $300 锁定名额。</p></article>
      <article class="card" style="background:#fff;"><h3>尾款</h3><p class="muted" style="margin:0;">出发前 30 天完成尾款支付。</p></article>
      <article class="card" style="background:#fff;"><h3>退改规则</h3><p class="muted" style="margin:0;">正式报名邮件中提供完整退改条款。</p></article>
    </div>
  </section>

  <section class="section grid cols-2"><article class="card"><h2 style="font-size:30px;">包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{included.map((item) => <li>{item}</li>)}</ul></article><article class="card"><h2 style="font-size:30px;">不包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncluded.map((item) => <li>{item}</li>)}</ul></article></section>

  <section id="faq" class="section card tone-blue"><h2 class="section-title">常见问题</h2>{zhFaq.map((f) => (<details style="margin-bottom:10px; border:1px solid #dce6f2; border-radius:12px; padding:12px; background:#fff;"><summary style="cursor:pointer; font-weight:700;">{f.q}</summary><p class="muted" style="margin:8px 0 0;">{f.a}</p></details>))}</section>

  <section id="register" class="section card tone-dark" style="margin-bottom:36px;"><h2 class="section-title">报名</h2><form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST"><input type="hidden" name="_subject" value="新的探索中国报名线索" /><input type="hidden" name="_next" value="https://explore-china-site.vercel.app/zh/success" /><input type="hidden" name="_captcha" value="false" /><div class="field"><label for="name">姓名</label><input id="name" name="name" required /></div><div class="field"><label for="email">邮箱</label><input id="email" type="email" name="email" required /></div><div class="field"><label for="phone">微信 / 电话（可选）</label><input id="phone" name="phone" /></div><div class="field"><label for="city">所在城市</label><input id="city" name="city" /></div><div class="field" style="grid-column:1 / -1;"><label for="goal">你为什么想参加这次行程？</label><textarea id="goal" name="goal" required></textarea></div><div style="grid-column:1 / -1; display:flex; gap:10px; justify-content:center;"><button class="btn btn-primary" type="submit">提交报名</button></div></form><p class="muted" style="text-align:center; margin-top:10px;">有问题？发邮件至 hello@explorationclub.ca</p></section>
</Layout>
