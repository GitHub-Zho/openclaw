---
import Layout from '../../../layouts/Layout.astro';
import { currentTrip, itinerary, faq, included, notIncluded, cityVisuals } from '../../../data/site';
---
<Layout title="探索中国 · 10天行程">
  <section class="section card" style="padding:34px; background:linear-gradient(180deg,#fff,#fbfaf6);">
    <p class="pill">旗舰线路</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:12px;">探索中国 · 10天暑期行程</h1>
    <p class="muted" style="font-size:18px; max-width:840px;">{currentTrip.summary}</p>

    <div class="grid cols-3" style="margin-top:14px;">
      <article class="card" style="padding:14px;"><p class="label" style="margin:0">路线</p><p style="margin:6px 0 0; font-weight:680;">上海 → 苏州 → 杭州 → 北京</p></article>
      <article class="card" style="padding:14px;"><p class="label" style="margin:0">价格</p><p style="margin:6px 0 0; font-weight:680;">CAD $3,000（不含国际机票）</p></article>
      <article class="card" style="padding:14px;"><p class="label" style="margin:0">住宿</p><p style="margin:6px 0 0; font-weight:680;">约 CAD $70/人/晚（约¥350）</p></article>
    </div>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px;">
      <a class="btn btn-primary" href="#register">报名入口</a>
      <a class="btn btn-secondary" href="/zh/handbook">查看手册</a>
    </div>
  </section>

  <section class="section grid cols-4">
    {cityVisuals.map((city) => (
      <figure style="margin:0;">
        <img class="photo" src={city.image} alt={city.alt} />
        <figcaption class="label" style="margin-top:8px; text-align:center;">{city.city}</figcaption>
      </figure>
    ))}
  </section>

  <section class="section card">
    <h2>行程安排（10天）</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:14px; background:#fff;">
          <p class="pill" style="margin-bottom:8px;">{d.day}</p>
          <h3 style="margin-bottom:6px;">{d.city}</h3>
          <p class="muted" style="margin:0;">{d.plan}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card"><h2 style="font-size:30px;">包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{included.map((item) => <li>{item}</li>)}</ul></article>
    <article class="card"><h2 style="font-size:30px;">不包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncluded.map((item) => <li>{item}</li>)}</ul></article>
  </section>

  <section id="faq" class="section card">
    <h2>常见问题</h2>
    {faq.map((f) => (
      <details style="margin-bottom:10px; border:1px solid #e7e7e2; border-radius:12px; padding:12px; background:#fff;">
        <summary style="cursor:pointer; font-weight:700;">{f.q}</summary>
        <p class="muted" style="margin:8px 0 0;">{f.a}</p>
      </details>
    ))}
  </section>

  <section id="register" class="section card" style="margin-bottom:36px;">
    <h2>报名</h2>
    <p class="muted">最终报名表单与时间节点将于近期发布。</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn btn-primary" href="#">开始报名</a>
      <a class="btn btn-secondary" href="#">接收通知</a>
    </div>
  </section>
</Layout>
