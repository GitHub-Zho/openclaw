---
import Layout from '../../layouts/Layout.astro';
import { cityVisuals } from '../../data/site';

const zhName: Record<string,string> = { Shanghai: '上海', Suzhou: '苏州', Hangzhou: '杭州', Beijing: '北京' };
const zhItinerary = [
  { day: '第1天', city: '上海', plan: '接机、入住、行前适应与本地支付/通信基础设置。' },
  { day: '第2天', city: '苏州', plan: '博物馆与江南文化体验，傍晚古运河与街区漫游后返程。' },
  { day: '第3天', city: '上海', plan: '豫园老城厢、外滩城市天际线与核心城区步行体验。' },
  { day: '第4天', city: '上海', plan: '弹性探索日：文化街区、特色餐饮与晚间社交活动。' },
  { day: '第5天', city: '杭州', plan: '西湖、灵隐寺与茶文化路线。' },
  { day: '第6天', city: '北京', plan: '北上转场，完成入住并进行首日城市导览。' },
  { day: '第7天', city: '北京', plan: '长城全天行程（具体段落按运营计划确认）。' },
  { day: '第8天', city: '北京', plan: '故宫与颐和园文化历史路线。' },
  { day: '第9天', city: '北京', plan: '本地学生交流日与结营社交夜。' },
  { day: '第10天', city: '北京', plan: '离境安排与返程支持。' },
];
---
<Layout title="探索中国手册" lang="zh" alternateHref="/handbook" alternateLabel="EN">
  <section id="guide" class="section card tone-sand" style="padding:34px;">
    <p class="pill">参与者手册</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:10px;">探索中国 · 参与者手册</h1>
    <p class="muted" style="max-width:860px; font-size:18px;">本页面用于统一展示路线结构、服务边界与每日安排，方便参与者快速判断是否匹配。</p>
    <div class="grid cols-3" style="margin-top:12px;">
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">路线</p><p style="margin:6px 0 0; font-weight:680;">上海 → 苏州 → 杭州 → 北京</p></div>
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">天数</p><p style="margin:6px 0 0; font-weight:680;">10 天</p></div>
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">费用</p><p style="margin:6px 0 0; font-weight:680;">CAD $3,000（不含国际机票）</p></div>
    </div>
  </section>

  <section id="overview" class="section grid cols-2">
    <article class="card tone-blue"><h2>项目定位</h2><p class="muted">本项目面向希望深入体验中国城市文化的学生群体，强调“清晰组织 + 本地体验 + 社交连接”。</p></article>
    <article class="card" style="padding:0; overflow:hidden;"><img class="photo media-wide" src={cityVisuals[3].image} alt={cityVisuals[3].alt} /></article>
  </section>

  <section id="destinations" class="section card tone-rose">
    <h2 class="section-title">城市参考</h2>
    <div class="grid cols-2">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px; background:#fff; display:grid; grid-template-columns:180px 1fr; gap:12px; align-items:start;"><img class="photo media-card" src={city.image} alt={city.alt} /><div><h3 style="margin:6px 0 8px;">{zhName[city.city] ?? city.city}</h3><p class="muted">对应城市的关键体验与节奏说明。</p></div></article>
      ))}
    </div>
  </section>

  <section id="itinerary" class="section card tone-dark" style="margin-bottom:36px;">
    <h2>10天概览</h2>
    <div class="grid cols-2">
      {zhItinerary.map((d) => (
        <article class="card" style="padding:12px; background:#fff; color:#151515; border-color:#ece7dd;"><p class="pill" style="margin-bottom:8px;">{d.day}</p><h3 style="margin-bottom:6px;">{d.city}</h3><p class="muted" style="margin:0; color:#545a60;">{d.plan}</p></article>
      ))}
    </div>
  </section>
</Layout>
