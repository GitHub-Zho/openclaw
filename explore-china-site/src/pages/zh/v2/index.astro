---
import Layout from '../../../layouts/Layout.astro';
import HeroTour from '../../../components/v3/HeroTour.astro';
import AnchorNav from '../../../components/v3/AnchorNav.astro';
import Carousel from '../../../components/v3/Carousel.astro';
import DayTabs from '../../../components/v3/DayTabs.astro';
import FaqList from '../../../components/v3/FaqList.astro';
import ApplyScaffold from '../../../components/v3/ApplyScaffold.astro';
import StickyApplyBar from '../../../components/v3/StickyApplyBar.astro';
import { cityVisuals } from '../../../data/site';

const cityMap: Record<string, string> = { Shanghai: '上海', Suzhou: '苏州', Hangzhou: '杭州', Beijing: '北京' };

const days = [
  {
    key: 'd1d2', label: 'D1-D2', title: '上海 + 苏州',
    body: '第1天 · 抵达安顿与城市基础设置\n第2天 · 苏州运河街区与博物馆节奏',
    hotel: '市中心 4 星', meals: '第2天起含早餐', transport: '接机 + 城际高铁'
  },
  {
    key: 'd3d5', label: 'D3-D5', title: '上海 + 杭州',
    body: '第3天 · 上海：豫园老城厢、外滩天际线步行体验\n第4天 · 上海：弹性探索日——文化街区与特色餐饮\n第5天 · 杭州：西湖、灵隐寺与龙井茶文化路线',
    hotel: '市中心4星 / 交通便利区域', meals: '每日早餐 + 指定团餐', transport: '城市通勤 + 步行文化路线'
  },
  {
    key: 'd6d10', label: 'D6-D10', title: '北京',
    body: '第6天：转场北京，城市初览\n第7天：长城全天行程\n第8天：故宫 + 颐和园历史路线\n第9天：本地学生交流日 + 结营社交夜\n第10天：离境安排与返程支持',
    hotel: '地铁友好区域4星酒店', meals: '早餐 + 结营晚餐', transport: '转场至北京 + 市内日程调度'
  },
];

const faq = [
  { q: '谁适合报名？', a: '以学生群体为主，提交资料后做基础匹配。' },
  { q: '订金是多少？', a: '席位确认后支付 CAD $300。' },
  { q: '多久会回复？', a: '多数有效申请在 24 小时内回复。' },
  { q: '这次行程只是普通观光吗？', a: '不是。行程包含本地学生交流活动与文化社交环节，帮助参与者建立真实的人际连接与文化理解。' },
];
---
<Layout title="探索中国 | v2" lang="zh" alternateHref="/v2/" alternateLabel="EN">
  <HeroTour
    badge="2026 夏季 · 学生项目"
    title="探索中国 2026"
    subtitle="专为学生设计的中国深度文化探索之旅，从城市到人情。"
    image="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1800&q=80"
    imageAlt="长城风景"
    route="上海 → 苏州 → 杭州 → 北京"
    price="CAD 3,000 / 人"
    departs="暑期批次 · 小团席位"
    stats={[{label:'时长', value:'10天'},{label:'城市', value:'4'},{label:'回复', value:'24小时内'}]}
    ctas={[{href:'#apply',label:'立即申请'},{href:'#itinerary',label:'查看行程',kind:'secondary'}]}
    asideLabel="行程速览"
    asideTitle="路线与出发信息"
    asideRouteLabel="路线"
    asidePriceLabel="起步价"
    asideDepartsLabel="出发批次"
    asideCtaLabel="查看席位"
  />

  <AnchorNav links={[{href:'#overview',label:'概览'},{href:'#media',label:'媒体'},{href:'#itinerary',label:'行程'},{href:'#inclusion',label:'包含项目'},{href:'#faq',label:'问答'},{href:'#apply',label:'报名'}]} ctaHref="#apply" ctaLabel="报名" />

  <section id="overview" class="section grid cols-3">
    <article class="card tone-sand"><p class="label">亮点</p><h3>地标 + 在地文化</h3><p class="muted">结构化节奏配合在地体验与社交连接。</p></article>
    <article class="card tone-sand"><p class="label">报名节奏</p><h3>提交 → 确认</h3><p class="muted">两步完成意向提交与席位确认。</p></article>
    <article class="card tone-sand"><p class="label">支持模型</p><h3>中英双语协同</h3><p class="muted">关键物流节点提供中英沟通支持。</p></article>
  </section>

  <section id="style" class="section card tone-blue">
    <h2 class="section-title">风格选择器</h2>
    <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:center; margin-bottom:12px;">
      <button class="btn btn-secondary js-style active" data-style="balanced" style="background:#111;color:#fff;border-color:#111;">均衡模式</button>
      <button class="btn btn-secondary js-style" data-style="culture">文化深度</button>
      <button class="btn btn-secondary js-style" data-style="social">社交优先</button>
    </div>
    <article class="card" id="style-panel">
      <p class="muted" data-style-body>标志性景点 + 适中节奏 + 社交时光。适合第一次来中国、希望全面体验的参与者。</p>
    </article>
  </section>

  <Carousel id="media" title="城市视觉轮播" items={cityVisuals.map((c)=>({image:c.image, alt:c.alt, label: cityMap[c.city] ?? c.city}))} />

  <DayTabs id="itinerary" title="行程标签" days={days} labels={{hotel:'住宿', meals:'餐食', transport:'交通'}} />

  <section id="inclusion" class="section grid cols-2">
    <article class="card tone-rose"><h3>包含</h3><ul class="muted"><li>住宿安排（学生友好房型，含拼房机制）</li><li>中国境内城市间及市内交通</li><li>核心景点门票与指定团队活动</li><li>组织方全程协调支持</li><li>关键节点中英双语支持</li></ul></article>
    <article class="card"><h3>不含</h3><ul class="muted"><li>国际往返机票</li><li>个人购物与可选升级消费</li><li>超出项目范围的个人支出</li></ul></article>
  </section>

  <FaqList id="faq" title="常见问题" items={faq} />

  <ApplyScaffold
    id="apply"
    title="先申请，再确认"
    subtitle="一次提交基础信息，我们会回复席位状态与下一步安排。"
    bullets={['回访会明确席位与确认时间。','此步骤不强制付款，先做匹配评估。','提供顾问联系方式便于跟进。']}
    labels={{ name:'姓名', email:'邮箱', phone:'电话 / WhatsApp', city:'所在城市', goal:'你为什么想参加这次行程？' }}
    submitLabel="提交申请"
    subject="探索中国 v2 线索"
    nextUrl="https://explore-china-site.vercel.app/zh/success"
  />

  <StickyApplyBar href="#apply" label="快速报名" />

  <script is:inline>
    const styleCopy = {
      balanced: '标志性景点 + 适中节奏 + 社交时光。适合第一次来中国、希望全面体验的参与者。',
      culture: '博物馆、历史遗址与本地社区深度探索。减少夜间活动，增加文化厚度。适合对历史与艺术感兴趣的学生。',
      social: '学生交流、美食探索、夜生活与城市活力。适合以拓展人脉为主要目标的参与者。',
    };
    const panel = document.querySelector('[data-style-body]');
    document.querySelectorAll('.js-style').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-style');
        if (panel && key && styleCopy[key]) panel.textContent = styleCopy[key];
        document.querySelectorAll('.js-style').forEach((b) => { b.style.background=''; b.style.color=''; b.style.borderColor=''; });
        btn.style.background='#111'; btn.style.color='#fff'; btn.style.borderColor='#111';
      });
    });
  </script>
</Layout>
