---
import Layout from '../../../layouts/Layout.astro';
import { cityVisuals } from '../../../data/site';
---
<Layout title="探索中国 V2">
  <section class="section card tone-dark" style="padding:42px; text-align:center;">
    <p class="pill">V2 重设计</p>
    <h1 style="font-size:clamp(40px,6vw,76px); margin:12px 0;">探索中国 2026</h1>
    <p class="muted section-sub">参考官方旅游指南与成熟旅行社详情页的信息架构，重建转化导向页面。</p>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;"><a class="btn btn-primary" href="#apply">立即报名</a><a class="btn btn-secondary" href="#guide">行前资料</a></div>
  </section>

  <section class="section card tone-sand">
    <h2 class="section-title">城市轮播</h2>
    <div class="carousel" id="v2-carousel-zh"><button class="carousel-btn prev" type="button">‹</button><div class="carousel-track">{cityVisuals.map((city) => (<article class="carousel-slide" style="padding:0;"><img class="photo media-hero" src={city.image} alt={city.alt} /><p style="text-align:center; margin:8px 0 0; font-weight:700;">{city.city}</p></article>))}</div><button class="carousel-btn next" type="button">›</button></div>
    <div class="carousel-dots" id="v2-carousel-zh-dots"></div>
  </section>

  <section id="guide" class="section card tone-blue">
    <h2 class="section-title">参考入口</h2>
    <div class="grid cols-2">
      <article class="card" style="background:#fff;"><h3>官方指南风格</h3><p><a class="text-link" href="https://www.travelchina.org.cn/en" target="_blank">travelchina.org.cn ↗</a></p></article>
      <article class="card" style="background:#fff;"><h3>行程细节风格</h3><p><a class="text-link" href="https://www.chinatravel.com/tour/classic-china-tour" target="_blank">chinatravel.com ↗</a></p></article>
    </div>
    <p class="muted" style="margin-top:10px;">素材说明：本页使用可复用公开素材，不直接拷贝第三方网站源图。</p>
  </section>

  <section id="apply" class="section card tone-dark" style="margin-bottom:36px;"><h2 class="section-title">报名</h2><form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST"><input type="hidden" name="_subject" value="探索中国V2报名" /><input type="hidden" name="_next" value="https://explore-china-site.vercel.app/zh/success" /><input type="hidden" name="_captcha" value="false" /><div class="field"><label for="name">姓名</label><input id="name" name="name" required /></div><div class="field"><label for="email">邮箱</label><input id="email" type="email" name="email" required /></div><div class="field" style="grid-column:1 / -1;"><label for="goal">你最期待什么</label><textarea id="goal" name="goal"></textarea></div><div style="grid-column:1 / -1; display:flex; justify-content:center;"><button class="btn btn-primary" type="submit">提交</button></div></form></section>

  <script is:inline>
    (() => {
      const root = document.getElementById('v2-carousel-zh'); if (!root) return;
      const track = root.querySelector('.carousel-track');
      const slides = Array.from(root.querySelectorAll('.carousel-slide'));
      const prev = root.querySelector('.prev'); const next = root.querySelector('.next');
      const dotsRoot = document.getElementById('v2-carousel-zh-dots');
      let idx = 0;
      const render = () => { track.style.transform = `translateX(-${idx * 100}%)`; if (dotsRoot) Array.from(dotsRoot.children).forEach((d, i) => d.classList.toggle('active', i === idx)); };
      if (dotsRoot) slides.forEach((_, i) => { const b = document.createElement('button'); b.addEventListener('click', () => { idx = i; render(); }); dotsRoot.appendChild(b); });
      prev?.addEventListener('click', () => { idx = (idx - 1 + slides.length) % slides.length; render(); });
      next?.addEventListener('click', () => { idx = (idx + 1) % slides.length; render(); });
      setInterval(() => { idx = (idx + 1) % slides.length; render(); }, 2800);
      render();
    })();
  </script>
</Layout>
