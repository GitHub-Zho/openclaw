---
import Layout from '../../../layouts/Layout.astro';
import HeroTour from '../../../components/v3/HeroTour.astro';
import AnchorNav from '../../../components/v3/AnchorNav.astro';
import Carousel from '../../../components/v3/Carousel.astro';
import DayTabs from '../../../components/v3/DayTabs.astro';
import FaqList from '../../../components/v3/FaqList.astro';
import ApplyScaffold from '../../../components/v3/ApplyScaffold.astro';
import StickyApplyBar from '../../../components/v3/StickyApplyBar.astro';
import { cityVisuals } from '../../../data/site';
import { cities } from '../../../data/cities';
import CitySectionTest from '../../../components/sections/CitySectionTest.astro';

const cityMap: Record<string, string> = { Shanghai: '上海', Suzhou: '苏州', Hangzhou: '杭州', Beijing: '北京' };

const days = [
  {
    key: 'd1d2', label: 'D1-D2', title: '上海 + 苏州',
    body: '第1天 · 抵达安顿与城市基础设置\n第2天 · 苏州运河街区与博物馆节奏',
    hotel: '市中心 4 星', meals: '第2天起含早餐', transport: '接机 + 城际高铁'
  },
  {
    key: 'd3d5', label: 'D3-D5', title: '上海 + 杭州',
    body: '第3天 · 上海：豫园老城厢、外滩天际线步行体验\n第4天 · 上海：弹性探索日——文化街区与特色餐饮\n第5天 · 杭州：西湖、灵隐寺与龙井茶文化路线',
    hotel: '市中心4星 / 交通便利区域', meals: '每日早餐 + 指定团餐', transport: '城市通勤 + 步行文化路线'
  },
  {
    key: 'd6d10', label: 'D6-D10', title: '北京',
    body: '第6天：转场北京，城市初览\n第7天：长城全天行程\n第8天：故宫 + 颐和园历史路线\n第9天：本地学生交流日 + 结营社交夜\n第10天：离境安排与返程支持',
    hotel: '地铁友好区域4星酒店', meals: '早餐 + 结营晚餐', transport: '转场至北京 + 市内日程调度'
  },
];

const timelineMapZh: Record<string, string[]> = {
  shanghai: ['抵达', '外滩夜景', '豫园', '城市漫步'],
  suzhou: ['当日往返', '园林', '博物馆', '运河夜景'],
  hangzhou: ['西湖', '灵隐寺', '茶村'],
  beijing: ['长城', '故宫', '颐和园', '交流', '结营'],
};

const faq = [
  { q: '谁适合报名？', a: '以学生群体为主，提交资料后做基础匹配。' },
  { q: '订金是多少？', a: '席位确认后支付 CAD $300。' },
  { q: '多久会回复？', a: '多数有效申请在 24 小时内回复。' },
  { q: '这次行程只是普通观光吗？', a: '不是。行程包含本地学生交流活动与文化社交环节，帮助参与者建立真实的人际连接与文化理解。' },
];
---
<Layout title="探索中国 | v2 测试版" lang="zh" alternateHref="/v2/" alternateLabel="EN">
  <HeroTour
    badge="2026 夏季 · 学生项目"
    title="探索中国 2026"
    subtitle="10天路线覆盖上海、苏州、杭州、北京，重点呈现城市文化、人文交流与在地体验。"
    image="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1800&q=80"
    imageAlt="长城风景"
    route="上海 → 苏州 → 杭州 → 北京"
    price="CAD 3,000 / 人"
    departs="暑期批次 · 小团席位"
    stats={[{label:'时长', value:'10天'},{label:'城市', value:'4'},{label:'回复', value:'24小时内'}]}
    ctas={[{href:'#itinerary',label:'查看行程'},{href:'#apply',label:'立即申请',kind:'secondary'}]}
    asideLabel="行程速览"
    asideTitle="路线与出发信息"
    asideRouteLabel="路线"
    asidePriceLabel="起步价"
    asideDepartsLabel="出发批次"
    asideCtaLabel="查看席位"
  />

  <AnchorNav links={[{href:'#overview',label:'概览'},{href:'#media',label:'媒体'},{href:'#itinerary',label:'行程'},{href:'#inclusion',label:'包含项目'},{href:'#faq',label:'问答'},{href:'#apply',label:'报名'}]} ctaHref="#apply" ctaLabel="报名" />

  <section id="overview" class="section grid cols-2">
    <article class="card tone-sand">
      <p class="label">项目定位</p>
      <h3>旅行产品优先，不是社团介绍页</h3>
      <p class="muted">这版测试页聚焦旅行决策：路线价值、城市体验、社交交流、报名边界，信息一屏可读。</p>
      <div class="grid cols-2" style="margin-top:10px;">
        <div class="card" style="background:#fff;"><p class="label">出发</p><p style="font-weight:700;margin:6px 0 0;">2026年7月</p></div>
        <div class="card" style="background:#fff;"><p class="label">规模</p><p style="font-weight:700;margin:6px 0 0;">最多20人</p></div>
      </div>
    </article>
    <article class="card tone-blue">
      <p class="label">本轮优化点</p>
      <ul class="muted" style="line-height:1.85; margin:0; padding-left:18px;">
        <li>城市模块统一为沉浸式结构。</li>
        <li>轮播图片加载策略优化。</li>
        <li>包含/不含模块视觉增强。</li>
        <li>中英页面保持结构一致。</li>
      </ul>
    </article>
  </section>

  <Carousel id="media" title="城市轮播（加载优化）" items={cityVisuals.map((c)=>({image:c.image, alt:c.alt, label: cityMap[c.city] ?? c.city}))} />

  <DayTabs id="itinerary" title="行程标签" days={days} labels={{hotel:'住宿', meals:'餐食', transport:'交通'}} />

  <section class="section">
    {cities.map((city, idx) => (
      <CitySectionTest city={city} lang="zh" eagerHero={idx === 0} timeline={timelineMapZh[city.id] ?? []} />
    ))}
  </section>

  <section id="inclusion" class="section grid cols-2">
    <article class="card tone-rose">
      <p class="label">包含</p>
      <h3>套餐内已覆盖项目</h3>
      <ul class="muted" style="line-height:1.85; margin:0; padding-left:18px;">
        <li>住宿安排（学生友好房型）</li>
        <li>城市间与市内交通</li>
        <li>核心景点与团队活动</li>
        <li>组织协调与关键节点支持</li>
      </ul>
    </article>
    <article class="card tone-dark">
      <p class="label">不含</p>
      <h3 style="color:#fff;">需自行准备部分</h3>
      <ul class="muted" style="line-height:1.85; margin:0; padding-left:18px; color:#d8d8d8;">
        <li>国际往返机票</li>
        <li>个人购物消费</li>
        <li>私人升级与额外开支</li>
      </ul>
    </article>
  </section>

  <FaqList id="faq" title="常见问题" items={faq} />

  <ApplyScaffold
    id="apply"
    title="先申请，再确认"
    subtitle="一次提交基础信息，我们会回复席位状态与下一步安排。"
    bullets={['回访会明确席位与确认时间。','此步骤不强制付款，先做匹配评估。','提供顾问联系方式便于跟进。']}
    labels={{ name:'姓名', email:'邮箱', phone:'电话 / WhatsApp', city:'所在城市', goal:'你为什么想参加这次行程？' }}
    submitLabel="提交申请"
    subject="探索中国 v2 线索"
    nextUrl="https://explore-china-site.vercel.app/zh/success"
  />

  <StickyApplyBar href="#apply" label="快速报名" />
</Layout>
