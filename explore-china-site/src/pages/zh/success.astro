---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="报名已提交" lang="zh" alternateHref="/success" alternateLabel="EN" minimalNav={true}>
  <section class="section card tone-blue" style="text-align:center; padding:48px; margin-top:48px;">
    <p class="pill">提交成功</p>
    <h1 style="font-size:clamp(34px,5vw,58px); margin-top:12px;">我们已收到你的报名 ✅</h1>
    <p class="muted section-sub">你的信息已进入候选队列，后续将通过邮箱联系你确认下一步与时间节点。</p>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
      <a class="btn btn-primary" href="/zh/trips/explore-china-2026-summer#register">再次提交</a>
      <a class="btn btn-secondary" href="/zh/handbook">查看手册</a>
    </div>
  </section>
</Layout>
