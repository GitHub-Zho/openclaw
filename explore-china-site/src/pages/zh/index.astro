---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/v1/HeroSection.astro';
import DestinationCarousel from '../../components/v1/DestinationCarousel.astro';
import DestinationGrid from '../../components/v1/DestinationGrid.astro';
import Faq from '../../components/v1/Faq.astro';
---
<Layout title="探索中国｜学生项目" lang="zh" alternateHref="/" alternateLabel="EN">
  <HeroSection isZh={true} />
  <DestinationCarousel isZh={true} />
  <DestinationGrid isZh={true} />

  <section id="itinerary" class="py-20">
    <div class="container">
      <p class="section-eyebrow">行程</p>
      <h2 class="section-title">10天路线概览</h2>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <article class="bg-white p-6 border border-stone-200">
          <h3 class="text-2xl font-semibold mb-2">第1-5天 · 上海/苏州/杭州</h3>
          <p class="text-stone-600 leading-7">完成抵达安顿，体验外滩与老城对比，进入苏州水乡与杭州西湖茶文化节奏。</p>
        </article>
        <article class="bg-white p-6 border border-stone-200">
          <h3 class="text-2xl font-semibold mb-2">第6-10天 · 北京</h3>
          <p class="text-stone-600 leading-7">以长城、故宫为核心锚点，安排学生交流活动与结营社交夜，最后统一离境支持。</p>
        </article>
      </div>
    </div>
  </section>

  <section id="guide" class="py-20 bg-white">
    <div class="container">
      <p class="section-eyebrow">攻略</p>
      <h2 class="section-title">出发中国前的准备</h2>
      <div class="grid md:grid-cols-4 gap-4 mt-8">
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">签证申请流程</h3><p class="text-stone-600 text-sm">准备材料与预约时间建议。</p></article>
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">移动支付设置</h3><p class="text-stone-600 text-sm">微信支付与支付宝开通要点。</p></article>
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">手机卡与网络</h3><p class="text-stone-600 text-sm">机场和市区可选的数据方案。</p></article>
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">高铁购票指南</h3><p class="text-stone-600 text-sm">购票渠道与乘车流程。</p></article>
      </div>
    </div>
  </section>

  <Faq isZh={true} />

  <section id="apply" class="py-20">
    <div class="container">
      <p class="section-eyebrow">申请</p>
      <h2 class="section-title">提交你的申请</h2>
      <form class="grid md:grid-cols-2 gap-4 mt-8">
        <input class="border border-stone-300 p-3 bg-white" aria-label="姓名" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="邮箱" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="电话" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="所在城市" />
        <textarea class="md:col-span-2 border border-stone-300 p-3 bg-white min-h-[120px]" aria-label="你的行程目标"></textarea>
        <button type="button" class="md:col-span-2 justify-self-start bg-red-700 text-white px-7 py-3 hover:bg-red-800 transition-colors">提交申请</button>
      </form>
    </div>
  </section>
</Layout>
