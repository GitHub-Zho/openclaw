---
import Layout from '../../layouts/Layout.astro';
import { cityVisuals } from '../../data/site';
---
<Layout title="探索中国｜Exploration & Travel Club">
  <section class="section grid cols-2" style="align-items:stretch;">
    <article class="card" style="padding:36px; background:linear-gradient(180deg,#fff,#faf9f5);">
      <p class="pill">2026 夏季 · 学生项目</p>
      <h1 style="margin-top:14px; max-width:700px;">
        以更清晰、更可靠的方式
        <br />
        探索中国
      </h1>
      <p class="muted" style="max-width:620px; margin-top:12px;">
        面向加拿大学生用户的 10 天线路：融合地标体验、本地文化、同龄交流与全程组织支持。
      </p>
      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:18px;">
        <a class="btn btn-primary" href="/zh/trips/explore-china-2026-summer">申请 2026 项目</a>
        <a class="btn btn-secondary" href="/zh/handbook">查看手册</a>
      </div>
      <p class="label" style="margin-top:10px;">价格透明 · 组织清晰 · 决策友好</p>
    </article>

    <article class="card" style="padding:0; overflow:hidden;">
      <img src={cityVisuals[0].image} alt={cityVisuals[0].alt} style="height:100%; min-height:440px; width:100%; object-fit:cover; filter:saturate(0.92) contrast(0.98);" />
    </article>
  </section>

  <section class="section card" style="padding:22px;">
    <div class="grid cols-4">
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">时长</p><p style="margin:6px 0 0; font-weight:680;">10 天</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">路线</p><p style="margin:6px 0 0; font-weight:680;">上海 → 苏州 → 杭州 → 北京</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">价格</p><p style="margin:6px 0 0; font-weight:680;">CAD $3,000（不含国际机票）</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">住宿</p><p style="margin:6px 0 0; font-weight:680;">约 CAD $70/人/晚（约¥350）</p></article>
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card">
      <h2 style="font-size:32px;">为什么值得参加</h2>
      <ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">
        <li>节奏平衡：核心行程固定 + 弹性探索时段</li>
        <li>社交导向：本地学生交流日 + 结营社交夜</li>
        <li>边界清晰：报名前可完整了解包含与不包含内容</li>
      </ul>
    </article>
    <article class="card">
      <h2 style="font-size:32px;">信任要点</h2>
      <div class="grid cols-2">
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">对象</p><p style="margin:6px 0 0; font-weight:680;">加拿大学生群体</p></div>
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">语言</p><p style="margin:6px 0 0; font-weight:680;">中英双语支持</p></div>
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">组织</p><p style="margin:6px 0 0; font-weight:680;">全程协调执行</p></div>
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">资料</p><p style="margin:6px 0 0; font-weight:680;">手册可直接决策</p></div>
      </div>
    </article>
  </section>

  <section class="section card">
    <h2>报名流程</h2>
    <div class="grid cols-3">
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">步骤 1</p><p style="margin:6px 0 4px; font-weight:680;">提交意向</p><p class="muted" style="font-size:14px; margin:0;">填写意向表并提交基础信息，进入候选名单。</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">步骤 2</p><p style="margin:6px 0 4px; font-weight:680;">确认席位</p><p class="muted" style="font-size:14px; margin:0;">确认房型偏好，查看细则并完成订金。</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">步骤 3</p><p style="margin:6px 0 4px; font-weight:680;">出发前说明会</p><p class="muted" style="font-size:14px; margin:0;">统一领取行前信息、紧急联系人与城市攻略。</p></article>
    </div>
  </section>
</Layout>
