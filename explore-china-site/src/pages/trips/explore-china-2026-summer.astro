---
import Layout from '../../layouts/Layout.astro';
import { currentTrip, itinerary, faq, highlights } from '../../data/site';
---
<Layout title={currentTrip.title}>
  <section class="section card" style="padding:28px;">
    <span class="pill">Current Flagship Trip</span>
    <h1 style="font-size:clamp(34px,5vw,60px); margin-top:10px;">Explore China</h1>
    <p class="muted" style="font-size:18px; margin-top:8px;">{currentTrip.duration} · {currentTrip.subtitle}</p>
    <p style="max-width:860px; margin-top:12px;">{currentTrip.summary}</p>

    <div class="grid" style="grid-template-columns:1fr 1fr; margin-top:14px;">
      <div class="card" style="background:#fafafa;">
        <p class="muted" style="margin:0">Package</p>
        <p style="font-size:22px; font-weight:700; margin:6px 0 0;">{currentTrip.priceCad}</p>
      </div>
      <div class="card" style="background:#fafafa;">
        <p class="muted" style="margin:0">Stay Assumption</p>
        <p style="font-size:22px; font-weight:700; margin:6px 0 0;">{currentTrip.accommodation}</p>
      </div>
    </div>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
      <a class="btn btn-primary" href="/handbook">Open Full Handbook</a>
      <a class="btn btn-secondary" href="#register">Apply Placeholder</a>
    </div>
  </section>

  <section class="section grid" style="grid-template-columns:repeat(3,1fr);">
    <img class="photo" src="https://images.unsplash.com/photo-1528164344705-47542687000d?auto=format&fit=crop&w=900&q=80" alt="Suzhou garden" />
    <img class="photo" src="https://images.unsplash.com/photo-1510332981392-36692a1b3bcd?auto=format&fit=crop&w=900&q=80" alt="Hangzhou lake" />
    <img class="photo" src="https://images.unsplash.com/photo-1599571234909-29ed5d1321d6?auto=format&fit=crop&w=900&q=80" alt="Great Wall" />
  </section>

  <section class="section card">
    <h2>Why this route</h2>
    <div class="grid" style="grid-template-columns:1fr 1fr;">
      {highlights.map((h) => (
        <div class="card" style="padding:12px; background:#fff;">
          <p style="margin:0; font-weight:600;">{h}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section card">
    <h2>10-Day Plan</h2>
    <div class="grid" style="grid-template-columns:1fr 1fr;">
      {itinerary.map((d) => (
        <article class="card" style="padding:14px;">
          <p class="pill" style="margin-bottom:8px;">{d.day}</p>
          <h3 style="margin-bottom:6px;">{d.city}</h3>
          <p class="muted" style="margin:0;">{d.plan}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="faq" class="section card">
    <h2>FAQ</h2>
    {faq.map((f) => (
      <details style="margin-bottom:10px; border:1px solid #e7e7e2; border-radius:12px; padding:12px; background:#fff;">
        <summary style="cursor:pointer; font-weight:700;">{f.q}</summary>
        <p class="muted" style="margin:8px 0 0;">{f.a}</p>
      </details>
    ))}
  </section>

  <section id="register" class="section card" style="margin-bottom:36px;">
    <h2>Registration</h2>
    <p class="muted">Official form placeholder. Replace with your real signup flow.</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn btn-primary" href="#">Apply Now</a>
      <a class="btn btn-secondary" href="#">Join Waitlist</a>
    </div>
  </section>
</Layout>
