---
import Layout from '../../layouts/Layout.astro';
import { currentTrip, itinerary, faq, included, notIncluded, cityVisuals } from '../../data/site';
---
<Layout title={currentTrip.title} lang="en" alternateHref="/zh/trips/explore-china-2026-summer" alternateLabel="中文">
  <section id="overview" class="section card tone-sand" style="padding:34px;">
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:12px; text-align:center;">{currentTrip.title}</h1>
    <p class="muted section-sub" style="font-size:18px;">A student-focused China route blending city highlights, food culture, local student exchange, and practical support from start to finish.</p>

    <div class="grid cols-4" style="margin-top:14px;">
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Route</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.subtitle}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Departure</p><p style="margin:6px 0 0; font-weight:680;">July 2026 (date TBC)</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Application closes</p><p style="margin:6px 0 0; font-weight:680;">May 31, 2026</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Group size</p><p style="margin:6px 0 0; font-weight:680;">Max 20 participants</p></article>
    </div>
    <p class="muted" style="text-align:center; margin-top:10px;">Contact: hello@explorationclub.ca</p>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; justify-content:center;">
      <a class="btn btn-primary" href="#register">Apply</a>
      <a class="btn btn-secondary" href="/handbook">Open Full Handbook</a>
    </div>
  </section>

  <section id="destinations" class="section card tone-dark">
    <h2 class="section-title">City carousel</h2>
    <div class="carousel" id="city-carousel-en">
      <button class="carousel-btn prev" type="button" aria-label="Previous city">‹</button>
      <div class="carousel-track">
        {cityVisuals.map((city) => (
          <article class="carousel-slide" style="padding:10px;">
            <img class="photo media-wide" src={city.image} alt={city.alt} />
            <p class="label" style="margin:8px 0 0; text-align:center; color:#fff;">{city.city}</p>
          </article>
        ))}
      </div>
      <button class="carousel-btn next" type="button" aria-label="Next city">›</button>
    </div>
    <div class="carousel-dots" id="city-carousel-en-dots"></div>
  </section>

  <section id="itinerary" class="section card">
    <h2 class="section-title">Day-by-day itinerary</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:14px; background:#fff;"><p class="pill" style="margin-bottom:8px;">{d.day}</p><h3 style="margin-bottom:6px;">{d.city}</h3><p class="muted" style="margin:0;">{d.plan}</p></article>
      ))}
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card"><h2 style="font-size:30px;">Included</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{included.map((item) => <li>{item}</li>)}</ul></article>
    <article class="card"><h2 style="font-size:30px;">Not included</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncluded.map((item) => <li>{item}</li>)}</ul></article>
  </section>

  <section id="faq" class="section card tone-blue">
    <h2 class="section-title">FAQ</h2>
    {faq.map((f) => (
      <details style="margin-bottom:10px; border:1px solid #dce6f2; border-radius:12px; padding:12px; background:#fff;"><summary style="cursor:pointer; font-weight:700;">{f.q}</summary><p class="muted" style="margin:8px 0 0;">{f.a}</p></details>
    ))}
  </section>

  <section class="section card tone-sand">
    <h2 class="section-title">Pricing & booking rules</h2>
    <div class="grid cols-3">
      <article class="card" style="background:#fff;"><h3>Deposit</h3><p class="muted" style="margin:0;">Reserve seat with CAD $300 deposit after confirmation call.</p></article>
      <article class="card" style="background:#fff;"><h3>Balance</h3><p class="muted" style="margin:0;">Remaining balance due 30 days before departure.</p></article>
      <article class="card" style="background:#fff;"><h3>Cancellation</h3><p class="muted" style="margin:0;">· Cancel 60+ days before departure: full refund minus CAD $50 processing fee<br/>· Cancel 30–59 days before: 50% refund<br/>· Cancel less than 30 days before: deposit (CAD $300) non-refundable</p></article>
    </div>
  </section>

  <section id="register" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">Apply for this program</h2>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="New Explore China application lead" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label for="name">Full name</label><input id="name" name="name" required /></div>
      <div class="field"><label for="email">Email</label><input id="email" type="email" name="email" required /></div>
      <div class="field"><label for="phone">WhatsApp / Phone (optional)</label><input id="phone" name="phone" /></div>
      <div class="field"><label for="city">Current city</label><input id="city" name="city" /></div>
      <div class="field" style="grid-column:1 / -1;"><label for="goal">Why do you want this trip?</label><textarea id="goal" name="goal" required></textarea></div>
      <div style="grid-column:1 / -1; display:flex; gap:10px; justify-content:center;"><button class="btn btn-primary" type="submit">Submit Application</button><a class="btn btn-secondary" href="/success">Preview success page</a></div>
    </form>
    <p class="muted" style="text-align:center; margin-top:10px;">Questions? Email hello@explorationclub.ca</p>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById('city-carousel-en');
      if (!root) return;
      const track = root.querySelector('.carousel-track');
      const slides = Array.from(root.querySelectorAll('.carousel-slide'));
      const prev = root.querySelector('.prev');
      const next = root.querySelector('.next');
      const dotsRoot = document.getElementById('city-carousel-en-dots');
      let idx = 0;
      const render = () => {
        track.style.transform = `translateX(-${idx * 100}%)`;
        if (dotsRoot) Array.from(dotsRoot.children).forEach((d, i) => d.classList.toggle('active', i === idx));
      };
      if (dotsRoot) {
        slides.forEach((_, i) => {
          const b = document.createElement('button');
          b.addEventListener('click', () => { idx = i; render(); });
          dotsRoot.appendChild(b);
        });
      }
      prev?.addEventListener('click', () => { idx = (idx - 1 + slides.length) % slides.length; render(); });
      next?.addEventListener('click', () => { idx = (idx + 1) % slides.length; render(); });
      setInterval(() => { idx = (idx + 1) % slides.length; render(); }, 2600);
      render();
    })();
  </script>
</Layout>
