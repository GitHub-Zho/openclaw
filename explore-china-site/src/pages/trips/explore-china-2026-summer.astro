---
import Layout from '../../layouts/Layout.astro';
import { currentTrip, itinerary, faq, included, notIncluded, cityVisuals } from '../../data/site';

const opsPlan = [
  { day: 'D1-D2', transport: 'Airport pickup + private transfer + intercity rail', stay: '4★ city-center hotel', meals: 'Breakfast from D2' },
  { day: 'D3-D5', transport: 'City transit + curated walking routes', stay: '4★ student-friendly rooms', meals: 'Daily breakfast + selected group meals' },
  { day: 'D6-D10', transport: 'Beijing transfer + local day routing', stay: '4★ transport-connected area', meals: 'Breakfast + celebration dinner' },
];
---
<Layout title={currentTrip.title}>
  <section class="section card tone-sand" style="padding:34px;">
    <p class="pill">Explore China · Flagship Route</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:12px; text-align:center;">{currentTrip.title}</h1>
    <p class="muted section-sub" style="font-size:18px;">A student-focused China route blending city highlights, food culture, local student exchange, and practical support from start to finish.</p>

    <div class="grid cols-3" style="margin-top:14px;">
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Route</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.subtitle}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Package</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.priceCad}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Accommodation</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.accommodation}</p></article>
    </div>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; justify-content:center;">
      <a class="btn btn-primary" href="#register">Apply</a>
      <a class="btn btn-secondary" href="/handbook">Open Full Handbook</a>
    </div>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">Trust & service confidence</h2>
    <div class="grid cols-4">
      <article class="card" style="background:#fff;"><p class="label">Response SLA</p><p style="font-weight:700; margin:6px 0 0;">Within 24h</p></article>
      <article class="card" style="background:#fff;"><p class="label">Language support</p><p style="font-weight:700; margin:6px 0 0;">EN / 中文</p></article>
      <article class="card" style="background:#fff;"><p class="label">Execution style</p><p style="font-weight:700; margin:6px 0 0;">Structured + Flexible</p></article>
      <article class="card" style="background:#fff;"><p class="label">Lead channel</p><p style="font-weight:700; margin:6px 0 0;">Form + Email follow-up</p></article>
    </div>
  </section>

  <section class="section grid cols-4">
    {cityVisuals.map((city) => (
      <figure style="margin:0;" class="card tone-blue">
        <img class="photo media-card" src={city.image} alt={city.alt} />
        <figcaption class="label" style="margin-top:8px; text-align:center;">{city.city}</figcaption>
      </figure>
    ))}
  </section>

  <section class="section card tone-dark">
    <h2 class="section-title">Dynamic media carousel</h2>
    <p class="muted section-sub">Autoplay carousel with visible controls (prev/next + dots) so motion is obvious.</p>
    <div class="carousel" id="city-carousel-en">
      <button class="carousel-btn prev" type="button" aria-label="Previous">‹</button>
      <div class="carousel-track">
        {cityVisuals.map((city) => (
          <article class="carousel-slide" style="padding:10px;">
            <img class="photo media-wide" src={city.image} alt={city.alt} />
            <p class="label" style="margin:8px 0 0; text-align:center; color:#fff;">{city.city}</p>
          </article>
        ))}
      </div>
      <button class="carousel-btn next" type="button" aria-label="Next">›</button>
    </div>
    <div class="carousel-dots" id="city-carousel-en-dots"></div>
  </section>

  <section class="section grid cols-2">
    <article class="card tone-rose">
      <h2 style="font-size:32px;">Experience depth</h2>
      <p class="muted">Beyond landmarks, each city has social and cultural context blocks designed for students.</p>
      <ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">
        <li>Arrival onboarding and practical setup</li>
        <li>Museum + heritage + local neighborhoods</li>
        <li>Dedicated student exchange and closing night</li>
      </ul>
    </article>
    <article class="card" style="padding:0; overflow:hidden;"><img class="photo media-wide" src={cityVisuals[0].image} alt={cityVisuals[0].alt} /></article>
  </section>

  <section class="section card">
    <h2 class="section-title">Day-by-day itinerary</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:14px; background:#fff;"><p class="pill" style="margin-bottom:8px;">{d.day}</p><h3 style="margin-bottom:6px;">{d.city}</h3><p class="muted" style="margin:0;">{d.plan}</p></article>
      ))}
    </div>
  </section>

  <section class="section card tone-sand">
    <h2 class="section-title">Pricing & booking rules</h2>
    <div class="grid cols-3">
      <article class="card" style="background:#fff;"><h3>Deposit</h3><p class="muted" style="margin:0;">Reserve seat with CAD $300 deposit after confirmation call.</p></article>
      <article class="card" style="background:#fff;"><h3>Balance</h3><p class="muted" style="margin:0;">Remaining balance due 30 days before departure.</p></article>
      <article class="card" style="background:#fff;"><h3>Cancellation</h3><p class="muted" style="margin:0;">Refund and change policy delivered with formal booking email.</p></article>
    </div>
  </section>

  <section class="section card tone-rose">
    <h2 class="section-title">Operational details (what happens in real execution)</h2>
    <div class="grid cols-3">
      {opsPlan.map((o) => (
        <article class="card" style="background:#fff;"><p class="pill">{o.day}</p><p class="muted" style="margin:10px 0 0;"><strong>Transport:</strong> {o.transport}</p><p class="muted" style="margin:8px 0 0;"><strong>Stay:</strong> {o.stay}</p><p class="muted" style="margin:8px 0 0;"><strong>Meals:</strong> {o.meals}</p></article>
      ))}
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card"><h2 style="font-size:30px;">Included</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{included.map((item) => <li>{item}</li>)}</ul></article>
    <article class="card"><h2 style="font-size:30px;">Not included</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncluded.map((item) => <li>{item}</li>)}</ul></article>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">Travel prep guide hub (inspired by official sites)</h2>
    <div class="grid cols-2">
      <article class="card" style="background:#fff;">
        <h3>Official travel preparation references</h3>
        <p class="muted">Visa-free entry, tax refund, transport and payment prep:</p>
        <p><a class="text-link" href="https://www.travelchina.org.cn/en" target="_blank">Travel China official portal ↗</a></p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>Detailed operator-style itinerary sample</h3>
        <p class="muted">Reference for hotel/meals/guide detail level:</p>
        <p><a class="text-link" href="https://www.chinatravel.com/tour/classic-china-tour" target="_blank">Classic China tour detail page ↗</a></p>
      </article>
    </div>
  </section>

  <section id="faq" class="section card tone-blue">
    <h2 class="section-title">FAQ</h2>
    {faq.map((f) => (
      <details style="margin-bottom:10px; border:1px solid #dce6f2; border-radius:12px; padding:12px; background:#fff;"><summary style="cursor:pointer; font-weight:700;">{f.q}</summary><p class="muted" style="margin:8px 0 0;">{f.a}</p></details>
    ))}
  </section>

  <section id="register" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">Apply for this program</h2>
    <p class="muted section-sub">Real submission form — lead capture + response workflow. We reply to valid applications within 24 hours.</p>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="New Explore China application lead" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label for="name">Full name</label><input id="name" name="name" required /></div>
      <div class="field"><label for="email">Email</label><input id="email" type="email" name="email" required /></div>
      <div class="field"><label for="phone">WhatsApp / Phone (optional)</label><input id="phone" name="phone" /></div>
      <div class="field"><label for="city">Current city</label><input id="city" name="city" /></div>
      <div class="field" style="grid-column:1 / -1;"><label for="goal">Why do you want this trip?</label><textarea id="goal" name="goal" required></textarea></div>
      <div style="grid-column:1 / -1; display:flex; gap:10px; justify-content:center;"><button class="btn btn-primary" type="submit">Submit Application</button><a class="btn btn-secondary" href="/success">Preview success page</a></div>
    </form>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById('city-carousel-en');
      if (!root) return;
      const track = root.querySelector('.carousel-track');
      const slides = Array.from(root.querySelectorAll('.carousel-slide'));
      const prev = root.querySelector('.prev');
      const next = root.querySelector('.next');
      const dotsRoot = document.getElementById('city-carousel-en-dots');
      let idx = 0;
      const render = () => {
        track.style.transform = `translateX(-${idx * 100}%)`;
        if (dotsRoot) {
          Array.from(dotsRoot.children).forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      };
      if (dotsRoot) {
        slides.forEach((_, i) => {
          const b = document.createElement('button');
          b.addEventListener('click', () => { idx = i; render(); });
          dotsRoot.appendChild(b);
        });
      }
      prev?.addEventListener('click', () => { idx = (idx - 1 + slides.length) % slides.length; render(); });
      next?.addEventListener('click', () => { idx = (idx + 1) % slides.length; render(); });
      setInterval(() => { idx = (idx + 1) % slides.length; render(); }, 2600);
      render();
    })();
  </script>
</Layout>
