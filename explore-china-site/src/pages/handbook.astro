---
import Layout from '../layouts/Layout.astro';
import { handbookSections, cityVisuals, itinerary } from '../data/site';
---
<Layout title="Explore China Handbook">
  <section class="section card" style="padding:30px;">
    <p class="pill">Participant Handbook</p>
    <h1 style="font-size:clamp(34px,5vw,62px); margin-top:10px;">Explore China Handbook</h1>
    <p class="muted" style="max-width:860px; font-size:18px;">
      This handbook gives participants a clear view of how the trip is structured,
      what support is included, and what to expect day by day.
    </p>
  </section>

  <section class="section grid" style="grid-template-columns:1fr 1fr;">
    <article class="card">
      <h2>Program intent</h2>
      <p class="muted" style="margin:0;">{handbookSections.intro}</p>
    </article>
    <article class="card" style="padding:0; overflow:hidden;">
      <img src={cityVisuals[0].image} alt={cityVisuals[0].alt} style="height:100%; min-height:260px; width:100%; object-fit:cover; filter:saturate(0.88) contrast(0.96) brightness(1.02);" />
    </article>
  </section>

  <section class="section card">
    <h2>City reference</h2>
    <div class="grid" style="grid-template-columns:repeat(4,1fr);">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px;">
          <img class="photo" src={city.image} alt={city.alt} style="height:150px;" />
          <h3 style="margin:10px 0 6px;">{city.city}</h3>
          <p class="muted" style="margin:0; font-size:14px;">
            {city.city === 'Shanghai' && 'Arrival support, Old Town and Bund atmosphere.'}
            {city.city === 'Suzhou' && 'Museum + garden + canal culture day.'}
            {city.city === 'Hangzhou' && 'West Lake and Lingyin Temple route.'}
            {city.city === 'Beijing' && 'Iconic heritage sites and final social day.'}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section grid" style="grid-template-columns:1fr 1fr;">
    <article class="card">
      <h3>Accommodation</h3>
      <p class="muted" style="margin:0;">{handbookSections.accommodation}</p>
    </article>
    <article class="card">
      <h3>Dietary & food policy</h3>
      <p class="muted" style="margin:0;">{handbookSections.dietary}</p>
    </article>
    <article class="card">
      <h3>Language support</h3>
      <p class="muted" style="margin:0;">{handbookSections.language}</p>
    </article>
    <article class="card">
      <h3>Safety and coordination</h3>
      <p class="muted" style="margin:0;">{handbookSections.safety}</p>
    </article>
  </section>

  <section class="section card" style="margin-bottom:36px;">
    <h2>10-day schedule snapshot</h2>
    <div class="grid" style="grid-template-columns:1fr 1fr;">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px;">
          <p class="pill" style="margin-bottom:8px;">{d.day}</p>
          <h3 style="margin-bottom:6px;">{d.city}</h3>
          <p class="muted" style="margin:0;">{d.plan}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
