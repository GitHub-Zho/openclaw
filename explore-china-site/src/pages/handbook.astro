---
import Layout from '../layouts/Layout.astro';
import { currentTrip, cityVisuals, itinerary, handbookSections } from '../data/site';
---
<Layout title="Explore China Handbook">
  <section class="section card" style="padding:28px;">
    <span class="pill">Handbook · Student-facing</span>
    <h1 style="font-size:clamp(34px,5vw,60px); margin-top:10px;">Explore China · Program Handbook</h1>
    <p class="muted" style="font-size:18px; max-width:860px;">This handbook page combines the approved trip structure, policy notes, and city-level highlights in one place for participants.</p>
  </section>

  <section class="section grid" style="grid-template-columns:1.1fr 1fr;">
    <article class="card">
      <h2>Trip Overview</h2>
      <p>{handbookSections.intro}</p>
      <p class="muted">Route: {currentTrip.subtitle} · Duration: {currentTrip.duration}</p>
      <p class="muted" style="margin-bottom:0;">Package: {currentTrip.priceCad}</p>
    </article>
    <article class="card" style="padding:0; overflow:hidden;">
      <img src={cityVisuals[0].image} alt={cityVisuals[0].alt} style="height:100%; min-height:264px; width:100%; object-fit:cover; filter:saturate(0.88) contrast(0.96) brightness(1.02);" />
    </article>
  </section>

  <section class="section card">
    <h2>City Highlights</h2>
    <div class="grid" style="grid-template-columns:repeat(4,1fr);">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px;">
          <img class="photo" src={city.image} alt={city.alt} style="height:160px;" />
          <h3 style="margin-top:10px; margin-bottom:6px;">{city.city}</h3>
          <p class="muted" style="margin:0; font-size:14px;">{city.city === 'Shanghai' && 'Yu Garden, Bund skyline, modern city rhythm'}{city.city === 'Suzhou' && 'Museum + classical gardens + canal atmosphere'}{city.city === 'Hangzhou' && 'West Lake, Lingyin Temple, tea-culture route'}{city.city === 'Beijing' && 'Great Wall, Forbidden City, Summer Palace'} </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section card">
    <h2>Program Notes</h2>
    <div class="grid" style="grid-template-columns:1fr 1fr;">
      <article class="card" style="padding:14px;">
        <h3>Accommodation</h3>
        <p class="muted" style="margin:0;">{handbookSections.accommodation}</p>
      </article>
      <article class="card" style="padding:14px;">
        <h3>Dietary</h3>
        <p class="muted" style="margin:0;">{handbookSections.dietary}</p>
      </article>
      <article class="card" style="padding:14px;">
        <h3>Language Support</h3>
        <p class="muted" style="margin:0;">{handbookSections.language}</p>
      </article>
      <article class="card" style="padding:14px;">
        <h3>Safety & Coordination</h3>
        <p class="muted" style="margin:0;">{handbookSections.safety}</p>
      </article>
    </div>
  </section>

  <section class="section card">
    <h2>10-Day Snapshot</h2>
    <div class="grid" style="grid-template-columns:1fr 1fr;">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px;">
          <p class="pill" style="margin-bottom:8px;">{d.day}</p>
          <h3 style="margin-bottom:6px;">{d.city}</h3>
          <p class="muted" style="margin:0;">{d.plan}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section card" style="margin-bottom:36px;">
    <h2>Application</h2>
    <p class="muted">Final registration workflow (dates, deposit, and form link) will be announced here.</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn btn-primary" href="/trips/explore-china-2026-summer#register">Go to Trip Registration</a>
      <a class="btn btn-secondary" href="/">Back to Home</a>
    </div>
  </section>
</Layout>
