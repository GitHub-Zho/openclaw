---
import Layout from '../layouts/Layout.astro';
import { handbookSections, cityVisuals, itinerary, currentTrip } from '../data/site';
---
<Layout title="Explore China Handbook" lang="en" alternateHref="/zh/handbook" alternateLabel="中文">
  <section id="guide" class="section card tone-sand" style="padding:34px;">
    <p class="pill">Participant Handbook</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:10px;">Explore China Handbook</h1>
    <p class="muted" style="max-width:860px; font-size:18px;">A single participant-facing page for route expectations, support policy, and day-by-day structure.</p>
    <div class="grid cols-3" style="margin-top:12px;">
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Route</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.subtitle}</p></div>
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Duration</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.duration}</p></div>
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Package</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.priceCad}</p></div>
    </div>
  </section>

  <section id="overview" class="section grid cols-2">
    <article class="card tone-blue">
      <h2>Program intent</h2>
      <p class="muted" style="margin:0 0 12px;">{handbookSections.intro}</p>
      <a class="btn btn-secondary" href="/trips/explore-china-2026-summer">View full trip flow</a>
    </article>
    <article class="card" style="padding:0; overflow:hidden;"><img class="photo media-wide" src={cityVisuals[3].image} alt={cityVisuals[3].alt} /></article>
  </section>

  <section id="destinations" class="section card tone-rose">
    <h2 class="section-title">City references</h2>
    <div class="grid cols-2">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px; background:#fff; display:grid; grid-template-columns:180px 1fr; gap:12px; align-items:start;">
          <img class="photo media-card" src={city.image} alt={city.alt} />
          <div>
            <h3 style="margin:6px 0 8px;">{city.city}</h3>
            <p class="muted">Key highlights and pacing notes for participant planning.</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="itinerary" class="section card tone-dark" style="margin-bottom:36px;">
    <h2>10-day schedule snapshot</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px; background:#fff; color:#151515; border-color:#ece7dd;"><p class="pill" style="margin-bottom:8px;">{d.day}</p><h3 style="margin-bottom:6px;">{d.city}</h3><p class="muted" style="margin:0; color:#545a60;">{d.plan}</p></article>
      ))}
    </div>
  </section>
</Layout>
