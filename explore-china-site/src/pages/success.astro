---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Application Received" lang="en" alternateHref="/zh/success" alternateLabel="中文" minimalNav={true}>
  <section class="section card tone-blue" style="text-align:center; padding:48px; margin-top:48px;">
    <p class="pill">Submission Successful</p>
    <h1 style="font-size:clamp(34px,5vw,58px); margin-top:12px;">You’re on the list ✅</h1>
    <p class="muted section-sub">We received your application details. A coordinator will reply by email with the next step and timeline.</p>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
      <a class="btn btn-primary" href="/trips/explore-china-2026-summer#register">Submit another response</a>
      <a class="btn btn-secondary" href="/handbook">Review handbook</a>
    </div>
  </section>
</Layout>
