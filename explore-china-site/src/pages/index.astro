---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/v1/HeroSection.astro';
import DestinationCarousel from '../components/v1/DestinationCarousel.astro';
import DestinationGrid from '../components/v1/DestinationGrid.astro';
import Faq from '../components/v1/Faq.astro';
---
<Layout title="Explore China | Student Program" lang="en" alternateHref="/zh/" alternateLabel="中文">
  <HeroSection />
  <DestinationCarousel />
  <DestinationGrid />

  <section id="itinerary" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Itinerary</p>
      <h2 class="section-title">10-Day Route Overview</h2>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <article class="bg-white p-6 border border-stone-200">
          <h3 class="text-2xl font-semibold mb-2">Days 1-5 · Shanghai / Suzhou / Hangzhou</h3>
          <p class="text-stone-600 leading-7">Arrival onboarding, Bund and old-town contrast, Suzhou canal heritage, and Hangzhou West Lake + tea culture rhythm.</p>
        </article>
        <article class="bg-white p-6 border border-stone-200">
          <h3 class="text-2xl font-semibold mb-2">Days 6-10 · Beijing</h3>
          <p class="text-stone-600 leading-7">Great Wall and Forbidden City anchors, student exchange activities, closing social night, and departure support.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="guide" class="py-20 bg-white">
    <div class="container">
      <p class="section-eyebrow">Guide</p>
      <h2 class="section-title">Planning a Trip to China?</h2>
      <div class="grid md:grid-cols-4 gap-4 mt-8">
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">How to Apply for a Chinese Visa</h3><p class="text-stone-600 text-sm">Document checklist and appointment timing.</p></article>
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">Setting Up Mobile Payments</h3><p class="text-stone-600 text-sm">WeChat Pay and Alipay setup basics.</p></article>
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">SIM Card & Connectivity</h3><p class="text-stone-600 text-sm">Airport and city options for data plans.</p></article>
        <article class="p-5 border border-stone-200 hover:-translate-y-1 transition-transform"><h3 class="font-semibold mb-2">High-Speed Rail Tickets</h3><p class="text-stone-600 text-sm">Booking channels and boarding tips.</p></article>
      </div>
    </div>
  </section>

  <Faq />

  <section id="apply" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Apply</p>
      <h2 class="section-title">Start Your Application</h2>
      <form class="grid md:grid-cols-2 gap-4 mt-8">
        <input class="border border-stone-300 p-3 bg-white" aria-label="Name" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Email" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Phone" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Current city" />
        <textarea class="md:col-span-2 border border-stone-300 p-3 bg-white min-h-[120px]" aria-label="Your travel goals"></textarea>
        <button type="button" class="md:col-span-2 justify-self-start bg-red-700 text-white px-7 py-3 hover:bg-red-800 transition-colors">Submit Application</button>
      </form>
    </div>
  </section>
</Layout>
