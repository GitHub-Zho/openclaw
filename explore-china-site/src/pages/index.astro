---
import Layout from '../layouts/Layout.astro';
import { site, currentTrip } from '../data/site';
---
<Layout title={`${site.name} · V3`}>
  <section class="section card" style="padding:32px;">
    <span class="pill">2026 Summer Program</span>
    <h1 style="max-width:860px; margin-top:12px;">
      Youth travel, done right.
      <br />
      Explore China with real local context.
    </h1>
    <p class="muted" style="max-width:760px;">
      A student-led trip designed for people who want more than sightseeing:
      city energy, culture, social connection, and practical support.
    </p>
    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:16px;">
      <a class="btn btn-primary" href={`/trips/${currentTrip.slug}`}>View Trip</a>
      <a class="btn btn-secondary" href="/handbook">Open Handbook</a>
    </div>
  </section>

  <section class="section grid" style="grid-template-columns:1.1fr 1fr;">
    <article class="card" style="padding:0; overflow:hidden;">
      <img src="https://images.unsplash.com/photo-1549692520-acc6669e2f0c?auto=format&fit=crop&w=1600&q=80" alt="Shanghai skyline" style="height:100%; min-height:336px; width:100%; object-fit:cover; filter:saturate(0.88) contrast(0.96) brightness(1.02);" />
    </article>
    <article class="card">
      <h2>{currentTrip.title}</h2>
      <p class="muted">{currentTrip.duration} · {currentTrip.subtitle}</p>
      <p style="font-size:22px; font-weight:700; margin:12px 0 8px;">{currentTrip.priceCad}</p>
      <p class="muted">{currentTrip.accommodation}</p>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px;">
        <span class="pill">Shanghai</span>
        <span class="pill">Suzhou</span>
        <span class="pill">Hangzhou</span>
        <span class="pill">Beijing</span>
      </div>
      <p style="margin-top:14px;"><a href={`/trips/${currentTrip.slug}`}>Read details →</a></p>
    </article>
  </section>

  <section class="section grid" style="grid-template-columns:repeat(3,1fr);">
    <article class="card">
      <h3>Immersive</h3>
      <p class="muted">More than landmarks — social blocks and local atmosphere.</p>
    </article>
    <article class="card">
      <h3>Student-friendly</h3>
      <p class="muted">Structured enough to be safe, flexible enough to be fun.</p>
    </article>
    <article class="card">
      <h3>Scalable</h3>
      <p class="muted">Built as a club platform for future multi-route programs.</p>
    </article>
  </section>
</Layout>
