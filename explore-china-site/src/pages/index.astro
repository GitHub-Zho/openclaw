---
import Layout from '../layouts/Layout.astro';
import { cityVisuals } from '../data/site';
---
<Layout title="Exploration & Travel Club">
  <section class="section grid cols-2" style="align-items:stretch;">
    <article class="card" style="padding:36px; background:linear-gradient(180deg,#fff,#faf9f5);">
      <p class="pill">Summer 2026 · Student-Led Program</p>
      <h1 style="margin-top:14px; max-width:700px;">
        Explore China with
        <br />
        confidence, culture, and real student energy.
      </h1>
      <p class="muted" style="max-width:620px; margin-top:12px;">
        A 10-day Canada-friendly program combining iconic landmarks, practical logistics support,
        and meaningful local-student exchange.
      </p>
      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:18px;">
        <a class="btn btn-primary" href="/trips/explore-china-2026-summer">Apply for 2026 Cohort</a>
        <a class="btn btn-secondary" href="/handbook">Read Handbook</a>
      </div>
      <p class="label" style="margin-top:10px;">Transparent package · Structured support · No hidden assumptions</p>
    </article>

    <article class="card" style="padding:0; overflow:hidden;">
      <img src={cityVisuals[0].image} alt={cityVisuals[0].alt} style="height:100%; min-height:440px; width:100%; object-fit:cover; filter:saturate(0.92) contrast(0.98);" />
    </article>
  </section>

  <section class="section card" style="padding:22px;">
    <div class="grid cols-4">
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Duration</p><p style="margin:6px 0 0; font-weight:680;">10 Days</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Route</p><p style="margin:6px 0 0; font-weight:680;">Shanghai → Suzhou → Hangzhou → Beijing</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Package</p><p style="margin:6px 0 0; font-weight:680;">CAD $3,000 (flight excluded)</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Stay</p><p style="margin:6px 0 0; font-weight:680;">~CAD $70/person/night (≈¥350)</p></article>
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card">
      <h2 style="font-size:32px;">Why students trust this program</h2>
      <ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">
        <li>Structured pacing with built-in free exploration windows</li>
        <li>Clear inclusion/exclusion boundaries before payment</li>
        <li>Local-student exchange day + social finale in Beijing</li>
      </ul>
    </article>
    <article class="card">
      <h2 style="font-size:32px;">Proof points</h2>
      <div class="grid cols-2">
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Audience</p><p style="margin:6px 0 0; font-weight:680;">Canada-based students</p></div>
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Language</p><p style="margin:6px 0 0; font-weight:680;">EN / 中文 support</p></div>
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Support</p><p style="margin:6px 0 0; font-weight:680;">On-trip coordination</p></div>
        <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Flow</p><p style="margin:6px 0 0; font-weight:680;">Decision-ready handbook</p></div>
      </div>
    </article>
  </section>

  <section class="section card">
    <h2>Application timeline</h2>
    <div class="grid cols-3">
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Step 1</p><p style="margin:6px 0 4px; font-weight:680;">Interest form</p><p class="muted" style="font-size:14px; margin:0;">Submit interest and profile to enter shortlist review.</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Step 2</p><p style="margin:6px 0 4px; font-weight:680;">Seat confirmation</p><p class="muted" style="font-size:14px; margin:0;">Receive package details, confirm rooming, and complete deposit.</p></article>
      <article class="card" style="padding:14px; background:#fcfbf8;"><p class="label" style="margin:0">Step 3</p><p style="margin:6px 0 4px; font-weight:680;">Pre-departure briefing</p><p class="muted" style="font-size:14px; margin:0;">Get logistics, safety contacts, and final city playbook.</p></article>
    </div>
  </section>

  <section class="section card tone-rose">
    <h2>City structure</h2>
    <div class="grid cols-4">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px; background:#fff;">
          <img class="photo media-card" src={city.image} alt={city.alt} />
          <h3 style="margin:10px 0 4px;">{city.city}</h3>
          <p class="muted" style="font-size:14px; margin:0;">
            {city.city === 'Shanghai' && 'Arrival onboarding, Bund skyline, and city orientation.'}
            {city.city === 'Suzhou' && 'Museum and canal culture with Jiangnan atmosphere.'}
            {city.city === 'Hangzhou' && 'West Lake, Lingyin Temple, and tea-culture route.'}
            {city.city === 'Beijing' && 'Great Wall, Forbidden City, and social closing day.'}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section card tone-dark">
    <h2>What students say this format solves</h2>
    <div class="grid cols-3">
      <article class="card" style="background:#fff; color:#151515;"><p style="margin:0; font-weight:680;">“I need structure, but not a rigid tour bus vibe.”</p><p class="muted" style="margin-top:8px; color:#5b6168;">Core activities are fixed; exploration windows are preserved.</p></article>
      <article class="card" style="background:#fff; color:#151515;"><p style="margin:0; font-weight:680;">“I don’t want hidden surprises in budget.”</p><p class="muted" style="margin-top:8px; color:#5b6168;">Inclusion / exclusion boundaries are shown before commitment.</p></article>
      <article class="card" style="background:#fff; color:#151515;"><p style="margin:0; font-weight:680;">“I want social connection, not solo drift.”</p><p class="muted" style="margin-top:8px; color:#5b6168;">Student exchange day + final social night create closure.</p></article>
    </div>
  </section>
</Layout>
