---
import Layout from '../layouts/Layout.astro';
import { currentTrip, cityVisuals } from '../data/site';
---
<Layout title="Exploration & Travel Club">
  <section class="section grid cols-2" style="align-items:stretch;">
    <article class="card" style="padding:36px; background:linear-gradient(180deg,#fff,#faf9f5);">
      <p class="pill">Summer 2026 · Student-Led Program</p>
      <h1 style="margin-top:14px; max-width:700px;">
        Explore China with
        <br />
        structure, style, and real local context.
      </h1>
      <p class="muted" style="max-width:620px; margin-top:12px;">
        A 10-day route designed for students who want both iconic landmarks and authentic city rhythm.
        You get clear logistics, social energy, and enough flexibility to enjoy the trip like real travelers.
      </p>
      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:18px;">
        <a class="btn btn-primary" href="/trips/explore-china-2026-summer">View Program</a>
        <a class="btn btn-secondary" href="/handbook">Read Handbook</a>
      </div>
    </article>

    <article class="card" style="padding:0; overflow:hidden;">
      <img
        src={cityVisuals[0].image}
        alt={cityVisuals[0].alt}
        style="height:100%; min-height:440px; width:100%; object-fit:cover; filter:saturate(0.9) contrast(0.98);"
      />
    </article>
  </section>

  <section class="section card" style="padding:22px;">
    <div class="grid cols-4">
      <article class="card" style="padding:14px; background:#fcfbf8;">
        <p class="label" style="margin:0">Duration</p>
        <p style="margin:6px 0 0; font-weight:680;">10 Days</p>
      </article>
      <article class="card" style="padding:14px; background:#fcfbf8;">
        <p class="label" style="margin:0">Route</p>
        <p style="margin:6px 0 0; font-weight:680;">Shanghai → Suzhou → Hangzhou → Beijing</p>
      </article>
      <article class="card" style="padding:14px; background:#fcfbf8;">
        <p class="label" style="margin:0">Package</p>
        <p style="margin:6px 0 0; font-weight:680;">CAD $3,000 (flight excluded)</p>
      </article>
      <article class="card" style="padding:14px; background:#fcfbf8;">
        <p class="label" style="margin:0">Stay</p>
        <p style="margin:6px 0 0; font-weight:680;">~¥350/person/night</p>
      </article>
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card">
      <h2 style="font-size:32px;">Why this program works</h2>
      <ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">
        <li>Balanced pace: structured highlights + free exploration blocks</li>
        <li>Student social design: local exchange day + closing social night</li>
        <li>Clear package scope and logistics support from start to finish</li>
      </ul>
    </article>

    <article class="card">
      <h2 style="font-size:32px;">Built for real decisions</h2>
      <p class="muted" style="margin-bottom:10px;">
        Before registration, participants can review route, package scope, inclusion boundaries,
        and FAQ in one place—no hidden assumptions.
      </p>
      <a class="btn btn-secondary" href="/trips/explore-china-2026-summer#faq">Review FAQ</a>
    </article>
  </section>

  <section class="section card">
    <h2>City structure</h2>
    <div class="grid cols-4">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px; background:#fff;">
          <img class="photo" src={city.image} alt={city.alt} style="height:180px;" />
          <h3 style="margin:10px 0 4px;">{city.city}</h3>
          <p class="muted" style="font-size:14px; margin:0;">
            {city.city === 'Shanghai' && 'Arrival support, Old Town, Bund skyline and city rhythm.'}
            {city.city === 'Suzhou' && 'Jiangnan atmosphere, museum, and canal-side cultural experience.'}
            {city.city === 'Hangzhou' && 'West Lake, Lingyin Temple, and tea-culture route.'}
            {city.city === 'Beijing' && 'Great Wall, Forbidden City, Summer Palace, and social finale.'}
          </p>
        </article>
      ))}
    </div>
  </section>
</Layout>
