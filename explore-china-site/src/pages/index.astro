---
import Layout from '../layouts/Layout.astro';
import { currentTrip, cityVisuals } from '../data/site';
---
<Layout title="Exploration & Travel Club">
  <section class="section grid cols-2">
    <article class="card" style="padding:32px;">
      <p class="pill">Student Program · Summer 2026</p>
      <h1 style="margin-top:12px; max-width:680px;">
        Explore China
        <br />
        with clarity, culture, and real local context.
      </h1>
      <p class="muted" style="max-width:620px; margin-top:12px;">
        This is a student-led 10-day route for people who want more than checklist tourism.
        You get structure where it matters, and freedom where it matters.
      </p>
      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px;">
        <a class="btn btn-primary" href="/trips/explore-china-2026-summer">View Program</a>
        <a class="btn btn-secondary" href="/handbook">Read Handbook</a>
      </div>
    </article>

    <article class="card" style="padding:0; overflow:hidden;">
      <img src={cityVisuals[0].image} alt={cityVisuals[0].alt} style="height:100%; min-height:420px; width:100%; object-fit:cover; filter:saturate(0.88) contrast(0.96) brightness(1.02);" />
    </article>
  </section>

  <section class="section card">
    <h2>Program at a glance</h2>
    <div class="grid cols-4">
      <article class="card" style="padding:14px;">
        <p class="label" style="margin:0">Duration</p>
        <p style="margin:6px 0 0; font-weight:680;">10 Days</p>
      </article>
      <article class="card" style="padding:14px;">
        <p class="label" style="margin:0">Route</p>
        <p style="margin:6px 0 0; font-weight:680;">Shanghai → Suzhou → Hangzhou → Beijing</p>
      </article>
      <article class="card" style="padding:14px;">
        <p class="label" style="margin:0">Package</p>
        <p style="margin:6px 0 0; font-weight:680;">CAD $3,000 (flight excluded)</p>
      </article>
      <article class="card" style="padding:14px;">
        <p class="label" style="margin:0">Stay</p>
        <p style="margin:6px 0 0; font-weight:680;">~¥350/person/night</p>
      </article>
    </div>
  </section>

  <section class="section card">
    <h2>Four-city structure</h2>
    <div class="grid cols-4">
      {cityVisuals.map((city) => (
        <article class="card" style="padding:12px;">
          <img class="photo" src={city.image} alt={city.alt} style="height:170px;" />
          <h3 style="margin:10px 0 4px;">{city.city}</h3>
          <p class="muted" style="font-size:14px; margin:0;">
            {city.city === 'Shanghai' && 'Arrival, city rhythm, Bund and Old Town.'}
            {city.city === 'Suzhou' && 'Jiangnan culture, museum and canal atmosphere.'}
            {city.city === 'Hangzhou' && 'West Lake, Lingyin Temple, tea culture.'}
            {city.city === 'Beijing' && 'Great Wall, Forbidden City, Summer Palace.'}
          </p>
        </article>
      ))}
    </div>
  </section>
</Layout>
