---
import Layout from '../layouts/Layout.astro';
import { site, currentTrip, highlights } from '../data/site';
---
<Layout title={`${site.name} · V1`}> 
  <section class="card" style="margin-top:18px; padding:28px;">
    <span class="pill">V1 Promo Site</span>
    <h1 style="font-size:clamp(30px, 5vw, 52px); margin:12px 0 10px; line-height:1.06; max-width:760px;">
      {site.name}
    </h1>
    <p class="muted" style="font-size:18px; max-width:760px; margin:0 0 16px;">{site.description}</p>
    <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:14px;">
      <a class="btn" href={`/trips/${currentTrip.slug}`}>View Current Trip</a>
      <a class="btn ghost" href={`/trips/${currentTrip.slug}#register`}>Registration Placeholder</a>
    </div>
  </section>

  <section class="grid" style="grid-template-columns:1.2fr 1fr; margin-top:18px;">
    <article class="card">
      <h2>Current Program</h2>
      <p><strong>{currentTrip.title}</strong></p>
      <p class="muted">{currentTrip.duration} · {currentTrip.subtitle}</p>
      <p>{currentTrip.priceCad}</p>
      <p class="muted">{currentTrip.accommodation}</p>
      <p><a href={`/trips/${currentTrip.slug}`}>Open trip details →</a></p>
    </article>

    <article class="card">
      <h2>What this trip feels like</h2>
      <ul class="muted" style="padding-left:18px; margin:0; line-height:1.7;">
        {highlights.map((h) => <li>{h}</li>)}
      </ul>
    </article>
  </section>

  <section class="grid" style="grid-template-columns:1fr 1fr; margin-top:18px;">
    <article class="card">
      <h2>About the club</h2>
      <p>We are a student-led travel community focused on exploration, connection, and practical support. Trips are curated to feel social, exciting, and manageable for students.</p>
      <p class="muted">Tone: friendly, clear, and experience-first — not rigid package tourism.</p>
    </article>
    <article class="card" id="contact">
      <h2>Contact (to be finalized)</h2>
      <p class="muted">Email: TBD · Instagram: TBD · WeChat: TBD</p>
      <p class="muted">Replace these placeholders before launch.</p>
    </article>
  </section>

  <section class="card" style="margin-top:18px;">
    <h2>Future Trips (reserved)</h2>
    <p class="muted">This structure is built to support multiple trip pages later. New routes can be added as separate slugs under <code>/trips/</code>.</p>
  </section>
</Layout>
