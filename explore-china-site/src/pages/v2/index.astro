---
import Layout from '../../layouts/Layout.astro';
import HeroTour from '../../components/v3/HeroTour.astro';
import AnchorNav from '../../components/v3/AnchorNav.astro';
import Carousel from '../../components/v3/Carousel.astro';
import DayTabs from '../../components/v3/DayTabs.astro';
import FaqList from '../../components/v3/FaqList.astro';
import ApplyScaffold from '../../components/v3/ApplyScaffold.astro';
import StickyApplyBar from '../../components/v3/StickyApplyBar.astro';
import { cityVisuals } from '../../data/site';
import { cities } from '../../data/cities';
import CitySectionTest from '../../components/sections/CitySectionTest.astro';

const days = [
  {
    key: 'd1d2', label: 'D1-D2', title: 'Shanghai + Suzhou',
    body: 'Day 1 · Arrival onboarding and city setup\nDay 2 · Suzhou canal district and museum rhythm',
    hotel: '4★ city-center', meals: 'Breakfast starts Day 2', transport: 'Airport transfer + intercity rail'
  },
  {
    key: 'd3d5', label: 'D3-D5', title: 'Shanghai + Hangzhou',
    body: 'Day 3 · Shanghai: Yu Garden, Old Town, Bund skyline walk\nDay 4 · Shanghai: Flexible city day — food district, culture spots\nDay 5 · Hangzhou: West Lake, Lingyin Temple, tea-culture route',
    hotel: '4★ city-center / transport-connected', meals: 'Daily breakfast + selected group meal', transport: 'City transit + curated walking routes'
  },
  {
    key: 'd6d10', label: 'D6-D10', title: 'Beijing',
    body: 'Day 6: Beijing transfer, city orientation\nDay 7: Great Wall full-day\nDay 8: Forbidden City + Summer Palace\nDay 9: Local student exchange + closing night\nDay 10: Departure support',
    hotel: '4★ transport-connected area', meals: 'Breakfast + closing celebration dinner', transport: 'Beijing transfer + local day routing'
  },
];

const timelineMap: Record<string, string[]> = {
  shanghai: ['Arrival', 'Bund Night', 'Yu Garden', 'City Walk'],
  suzhou: ['Day Trip', 'Garden', 'Museum', 'Canal Night'],
  hangzhou: ['West Lake', 'Temple', 'Tea Village'],
  beijing: ['Wall', 'Forbidden City', 'Summer Palace', 'Exchange', 'Closing Night'],
};

const faq = [
  { q: 'Who can join?', a: 'Student-focused intake with profile review.' },
  { q: 'How much is the deposit?', a: 'CAD $300 after seat confirmation.' },
  { q: 'How quickly do you reply?', a: 'Most qualified leads receive an update within 24 hours.' },
  { q: 'Is this only sightseeing?', a: 'No. It includes local student exchange and cultural social blocks.' },
];
---
<Layout title="Explore China | v2 test" lang="en" alternateHref="/zh/v2/" alternateLabel="中文">
  <HeroTour
    badge="Summer 2026 · Student Program"
    title="Explore China 2026"
    subtitle="A 10-day student journey through Shanghai, Suzhou, Hangzhou, and Beijing — built for culture, people, and real local context."
    image="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1800&q=80"
    imageAlt="Great Wall landscape"
    route="Shanghai → Suzhou → Hangzhou → Beijing"
    price="CAD 3,000 / traveler"
    departs="Summer windows · small-group seats"
    stats={[{label:'Duration', value:'10 days'},{label:'Cities', value:'4'},{label:'Response', value:'<24h'}]}
    ctas={[{href:'#itinerary',label:'See itinerary'},{href:'#apply',label:'Apply now',kind:'secondary'}]}
  />

  <AnchorNav links={[{href:'#overview',label:'Overview'},{href:'#media',label:'Media'},{href:'#itinerary',label:'Itinerary'},{href:'#inclusion',label:'Inclusions'},{href:'#faq',label:'FAQ'},{href:'#apply',label:'Apply'}]} ctaHref="#apply" ctaLabel="Apply" />

  <section id="overview" class="section grid cols-2">
    <article class="card tone-sand">
      <p class="label">Program positioning</p>
      <h3>Travel-first, not club-first</h3>
      <p class="muted">This page is designed as a travel product: route clarity, destination quality, social exchange, and booking certainty in one flow.</p>
      <div class="grid cols-2" style="margin-top:10px;">
        <div class="card" style="background:#fff;"><p class="label">Departure</p><p style="font-weight:700;margin:6px 0 0;">July 2026</p></div>
        <div class="card" style="background:#fff;"><p class="label">Group size</p><p style="font-weight:700;margin:6px 0 0;">Max 20</p></div>
      </div>
    </article>
    <article class="card tone-blue">
      <p class="label">What makes this stronger</p>
      <ul class="muted" style="line-height:1.85; margin:0; padding-left:18px;">
        <li>Immersive city modules with visuals and context.</li>
        <li>Faster-loading destination carousel.</li>
        <li>Clear included / not included boundaries.</li>
        <li>Bilingual parity maintained EN/ZH.</li>
      </ul>
    </article>
  </section>

  <Carousel id="media" title="City carousel (optimized)" items={cityVisuals.map((c)=>({image:c.image, alt:c.alt, label:c.city}))} />

  <DayTabs id="itinerary" title="Itinerary tabs" days={days} />

  <section class="section">
    {cities.map((city, idx) => (
      <CitySectionTest city={city} lang="en" eagerHero={idx === 0} timeline={timelineMap[city.id] ?? []} />
    ))}
  </section>

  <section id="inclusion" class="section grid cols-2">
    <article class="card tone-rose">
      <p class="label">Included</p>
      <h3>What you get in this package</h3>
      <ul class="muted" style="line-height:1.85; margin:0; padding-left:18px;">
        <li>4★ accommodation package</li>
        <li>Intercity and local transport</li>
        <li>Core attractions and team activities</li>
        <li>Bilingual coordination support</li>
      </ul>
    </article>
    <article class="card tone-dark">
      <p class="label">Not included</p>
      <h3 style="color:#fff;">Prepare these separately</h3>
      <ul class="muted" style="line-height:1.85; margin:0; padding-left:18px; color:#d8d8d8;">
        <li>International flights</li>
        <li>Personal shopping</li>
        <li>Private upgrades</li>
      </ul>
    </article>
  </section>

  <FaqList id="faq" title="FAQ" items={faq} />

  <ApplyScaffold
    id="apply"
    title="Apply with confidence"
    subtitle="Share your profile once. We return seat status and next-step timing in one response."
    bullets={['Response ETA included in follow-up.','No forced payment at this step.','Direct advisor contact in response.']}
    labels={{ name:'Name', email:'Email', phone:'Phone / WhatsApp', city:'Current city', goal:'Why do you want this trip?' }}
    submitLabel="Submit"
    subject="Explore China v2 lead"
    nextUrl="https://explore-china-site.vercel.app/success"
  />

  <StickyApplyBar href="#apply" label="Quick Apply" />
</Layout>
