---
import Layout from '../../layouts/Layout.astro';
import { cityVisuals } from '../../data/site';
import Carousel from '../../components/v3/Carousel.astro';
import DayTabs from '../../components/v3/DayTabs.astro';
import FaqList from '../../components/v3/FaqList.astro';

const days = [
  { key: 'd1', label: 'D1-D2', title: 'Shanghai + Suzhou', body: 'Arrival onboarding, payments/SIM setup, Jiangnan museum and canal district route.', hotel:'4★ City Center', meals:'Breakfast from D2', transport:'Airport transfer + intercity rail' },
  { key: 'd3', label: 'D3-D5', title: 'Shanghai + Hangzhou', body: 'Bund/Old Town contrast, West Lake, temple and tea-culture sequence.', hotel:'4★ Student-friendly rooms', meals:'Daily breakfast + selected lunches', transport:'City transit + curated walks' },
  { key: 'd6', label: 'D6-D10', title: 'Beijing', body: 'Great Wall, Forbidden City, Summer Palace and exchange-day social finale.', hotel:'4★ Metro-connected area', meals:'Breakfast + closing dinner', transport:'High-speed transfer + day routing' },
];
const faq = [
  { q:'Who can join?', a:'Student-focused intake with profile review.' },
  { q:'How much is deposit?', a:'CAD $300 after seat confirmation.' },
  { q:'How fast is reply?', a:'Within 24 hours for valid leads.' },
];
---
<Layout title="Explore China V3">
  <section class="section card tone-dark" style="padding:42px; text-align:center;" id="overview">
    <p class="pill">V3 Experience Rebuild</p>
    <h1 style="font-size:clamp(40px,6vw,76px); margin:12px 0;">Explore China 2026</h1>
    <p class="muted section-sub">Interaction-parity architecture with reusable Astro components.</p>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;"><a class="btn btn-primary" href="#apply">Apply Now</a><a class="btn btn-secondary" href="#itinerary">See Itinerary</a></div>
  </section>

  <section class="section card" style="position:sticky; top:70px; z-index:12; background:#fff;"><div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;"><a class="btn btn-secondary" href="#overview">Overview</a><a class="btn btn-secondary" href="#media">Media</a><a class="btn btn-secondary" href="#itinerary">Itinerary</a><a class="btn btn-secondary" href="#inclusion">Inclusion</a><a class="btn btn-secondary" href="#faq">FAQ</a><a class="btn btn-primary" href="#apply">Apply</a></div></section>

  <section class="section card tone-blue">
    <h2 class="section-title">Tour style selector</h2>
    <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap; margin-bottom:10px;"><button class="btn btn-secondary style-tab" data-style="balanced">Balanced</button><button class="btn btn-secondary style-tab" data-style="culture">Culture-heavy</button><button class="btn btn-secondary style-tab" data-style="social">Social-first</button></div>
    <article class="card" id="style-panel" style="background:#fff; max-width:900px; margin:0 auto;"><h3 id="style-title">Balanced format</h3><p class="muted" id="style-body">Core landmarks + manageable pace + social moments.</p></article>
  </section>

  <Carousel id="media" title="City visual carousel" items={cityVisuals.map((c)=>({image:c.image, alt:c.alt, label:c.city}))} />
  <DayTabs id="itinerary" title="Day-tabs itinerary" days={days} />

  <section class="section grid cols-2" id="inclusion"><article class="card tone-rose"><h3>Included</h3><ul class="muted"><li>4★ accommodation package</li><li>Intercity transfers and planned routing</li><li>Core attractions and exchange activity</li></ul></article><article class="card"><h3>Not included</h3><ul class="muted"><li>International flights</li><li>Personal shopping</li><li>Private upgrades</li></ul></article></section>

  <FaqList id="faq" title="FAQ" items={faq} />

  <section id="apply" class="section card tone-dark" style="margin-bottom:36px;"><h2 class="section-title">Apply</h2><form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST"><input type="hidden" name="_subject" value="Explore China V3 lead" /><input type="hidden" name="_next" value="https://explore-china-site.vercel.app/success" /><input type="hidden" name="_captcha" value="false" /><div class="field"><label>Name</label><input name="name" required /></div><div class="field"><label>Email</label><input name="email" type="email" required /></div><div class="field" style="grid-column:1/-1;"><label>Goal</label><textarea name="goal"></textarea></div><div style="grid-column:1/-1;display:flex;justify-content:center;"><button class="btn btn-primary" type="submit">Submit</button></div></form></section>

  <a href="#apply" style="position:fixed; right:16px; bottom:20px; z-index:30;" class="btn btn-primary">Quick Apply</a>

  <script is:inline>
    (()=>{const styles={balanced:['Balanced format','Core landmarks + manageable pace + social moments.'],culture:['Culture-heavy format','More museums, historical narratives, deeper context modules.'],social:['Social-first format','More peer exchange, evening social activities, lighter museum load.']};const st=document.getElementById('style-title');const sb=document.getElementById('style-body');document.querySelectorAll('.style-tab').forEach(btn=>btn.onclick=()=>{const s=styles[btn.dataset.style];st.textContent=s[0];sb.textContent=s[1];});})();
  </script>
</Layout>
