---
import Layout from '../../layouts/Layout.astro';
import { cityVisuals } from '../../data/site';

const days = [
  { key: 'd1', label: 'D1-D2', title: 'Shanghai + Suzhou', body: 'Arrival onboarding, payments/SIM setup, Jiangnan museum and canal district route.' },
  { key: 'd3', label: 'D3-D5', title: 'Shanghai + Hangzhou', body: 'Bund/Old Town contrast, West Lake, temple and tea-culture sequence.' },
  { key: 'd6', label: 'D6-D10', title: 'Beijing', body: 'Great Wall, Forbidden City, Summer Palace and exchange-day social finale.' },
];
---
<Layout title="Explore China V3">
  <section class="section card tone-dark" style="padding:42px; text-align:center;" id="overview">
    <p class="pill">V3 Experience Rebuild</p>
    <h1 style="font-size:clamp(40px,6vw,76px); margin:12px 0;">Explore China 2026</h1>
    <p class="muted section-sub">Interaction-parity architecture: sticky jump nav, media carousel, day tabs, accordion FAQ, and conversion form.</p>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
      <a class="btn btn-primary" href="#apply">Apply Now</a>
      <a class="btn btn-secondary" href="#itinerary">See Itinerary</a>
    </div>
  </section>

  <section class="section card" style="position:sticky; top:70px; z-index:12; background:#fff;">
    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      <a class="btn btn-secondary" href="#overview">Overview</a>
      <a class="btn btn-secondary" href="#media">Media</a>
      <a class="btn btn-secondary" href="#itinerary">Itinerary</a>
      <a class="btn btn-secondary" href="#inclusion">Inclusion</a>
      <a class="btn btn-secondary" href="#faq">FAQ</a>
      <a class="btn btn-primary" href="#apply">Apply</a>
    </div>
  </section>

  <section class="section card tone-sand" id="media">
    <h2 class="section-title">City visual carousel</h2>
    <div class="carousel" id="v3-carousel">
      <button class="carousel-btn prev" type="button" aria-label="Previous">‹</button>
      <div class="carousel-track">
        {cityVisuals.map((city) => (
          <article class="carousel-slide"><img class="photo media-hero" src={city.image} alt={city.alt} /><p style="text-align:center; margin:8px 0 0; font-weight:700;">{city.city}</p></article>
        ))}
      </div>
      <button class="carousel-btn next" type="button" aria-label="Next">›</button>
    </div>
    <div class="carousel-dots" id="v3-carousel-dots"></div>
  </section>

  <section class="section card tone-blue" id="itinerary">
    <h2 class="section-title">Day-tabs itinerary</h2>
    <div style="display:flex; justify-content:center; gap:8px; flex-wrap:wrap; margin-bottom:10px;">
      {days.map((d, i) => <button class="btn btn-secondary v3-day" data-day={d.key} data-active={i===0?'1':'0'}>{d.label}</button>)}
    </div>
    <article class="card" id="v3-day-panel" style="max-width:900px; margin:0 auto; background:#fff;">
      <p class="pill">{days[0].label}</p>
      <h3 id="v3-day-title" style="margin:10px 0 6px;">{days[0].title}</h3>
      <p class="muted" id="v3-day-body" style="margin:0;">{days[0].body}</p>
    </article>
  </section>

  <section class="section grid cols-2" id="inclusion">
    <article class="card tone-rose"><h3>Included</h3><ul class="muted"><li>4★ accommodation package</li><li>Intercity transfers and planned routing</li><li>Core attractions and exchange activity</li></ul></article>
    <article class="card"><h3>Not included</h3><ul class="muted"><li>International flights</li><li>Personal shopping</li><li>Private upgrades</li></ul></article>
  </section>

  <section id="faq" class="section card tone-blue">
    <h2 class="section-title">FAQ</h2>
    <details><summary>Who can join?</summary><p class="muted">Student-focused intake with profile review.</p></details>
    <details><summary>How much is deposit?</summary><p class="muted">CAD $300 after seat confirmation.</p></details>
    <details><summary>How fast is reply?</summary><p class="muted">Within 24 hours for valid leads.</p></details>
  </section>

  <section id="apply" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">Apply</h2>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="Explore China V3 lead" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label>Name</label><input name="name" required /></div>
      <div class="field"><label>Email</label><input name="email" type="email" required /></div>
      <div class="field" style="grid-column:1/-1;"><label>Goal</label><textarea name="goal"></textarea></div>
      <div style="grid-column:1/-1;display:flex;justify-content:center;"><button class="btn btn-primary" type="submit">Submit</button></div>
    </form>
  </section>

  <script is:inline>
    (() => {
      const c = document.getElementById('v3-carousel');
      if (c) {
        const track = c.querySelector('.carousel-track');
        const slides = [...c.querySelectorAll('.carousel-slide')];
        const prev = c.querySelector('.prev');
        const next = c.querySelector('.next');
        const dotsRoot = document.getElementById('v3-carousel-dots');
        let i = 0;
        const render = () => {
          track.style.transform = `translateX(-${i * 100}%)`;
          [...dotsRoot.children].forEach((d, idx) => d.classList.toggle('active', idx === i));
        };
        slides.forEach((_, idx) => { const b=document.createElement('button'); b.onclick=()=>{i=idx;render();}; dotsRoot.appendChild(b); });
        prev.onclick = () => { i = (i - 1 + slides.length) % slides.length; render(); };
        next.onclick = () => { i = (i + 1) % slides.length; render(); };
        setInterval(() => { i = (i + 1) % slides.length; render(); }, 3000);
        render();
      }
      const model = {
        d1: {label:'D1-D2', title:'Shanghai + Suzhou', body:'Arrival onboarding, payments/SIM setup, Jiangnan museum and canal district route.'},
        d3: {label:'D3-D5', title:'Shanghai + Hangzhou', body:'Bund/Old Town contrast, West Lake, temple and tea-culture sequence.'},
        d6: {label:'D6-D10', title:'Beijing', body:'Great Wall, Forbidden City, Summer Palace and exchange-day social finale.'}
      };
      const title = document.getElementById('v3-day-title');
      const body = document.getElementById('v3-day-body');
      const pill = document.querySelector('#v3-day-panel .pill');
      document.querySelectorAll('.v3-day').forEach(btn => {
        btn.addEventListener('click', () => {
          const key = btn.dataset.day; const d = model[key];
          pill.textContent = d.label; title.textContent = d.title; body.textContent = d.body;
          document.querySelectorAll('.v3-day').forEach(b => b.dataset.active='0');
          btn.dataset.active='1';
        });
      });
    })();
  </script>
</Layout>
