---
import Layout from '../../layouts/Layout.astro';
import { cityVisuals } from '../../data/site';

const highlights = [
  { k: 'Response SLA', v: '24h' },
  { k: 'Support', v: 'EN/中文' },
  { k: 'Format', v: 'Structured + Flexible' },
  { k: 'Duration', v: '10 Days' },
];

const itinerary = [
  ['D1-D2','Shanghai + Suzhou','Arrival onboarding, payments/SIM setup, Jiangnan museum + canal atmosphere.'],
  ['D3-D5','Shanghai + Hangzhou','Old Town/Bund contrast, West Lake + temple + tea-culture route.'],
  ['D6-D10','Beijing','Great Wall, Forbidden City, Summer Palace, exchange day + social closing.'],
];
---
<Layout title="Explore China V2">
  <section class="section card tone-dark" style="padding:42px; text-align:center;">
    <p class="pill">V2 Redesign · Reference-Inspired</p>
    <h1 style="font-size:clamp(40px,6vw,76px); margin:12px 0;">Explore China 2026</h1>
    <p class="muted section-sub">A conversion-first travel program page inspired by official-guide and operator-detail layouts.</p>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
      <a class="btn btn-primary" href="#apply">Apply Now</a>
      <a class="btn btn-secondary" href="#guide">Travel Prep Guide</a>
    </div>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">Confidence panel</h2>
    <div class="grid cols-4">
      {highlights.map((h) => (<article class="card" style="background:#fff;"><p class="label">{h.k}</p><p style="font-weight:700; margin:6px 0 0;">{h.v}</p></article>))}
    </div>
  </section>

  <section class="section card tone-sand">
    <h2 class="section-title">City visual carousel</h2>
    <div class="carousel" id="v2-carousel">
      <button class="carousel-btn prev" type="button" aria-label="Previous">‹</button>
      <div class="carousel-track">
        {cityVisuals.map((city) => (
          <article class="carousel-slide" style="padding:0;">
            <img class="photo media-hero" src={city.image} alt={city.alt} />
            <p style="text-align:center; margin:8px 0 0; font-weight:700;">{city.city}</p>
          </article>
        ))}
      </div>
      <button class="carousel-btn next" type="button" aria-label="Next">›</button>
    </div>
    <div class="carousel-dots" id="v2-carousel-dots"></div>
  </section>

  <section class="section card tone-rose">
    <h2 class="section-title">Operator-level execution detail</h2>
    <div class="grid cols-3">
      {itinerary.map((r) => (
        <article class="card" style="background:#fff;"><p class="pill">{r[0]}</p><h3 style="margin:10px 0 6px;">{r[1]}</h3><p class="muted" style="margin:0;">{r[2]}</p></article>
      ))}
    </div>
  </section>

  <section id="guide" class="section card tone-blue">
    <h2 class="section-title">Official prep references</h2>
    <div class="grid cols-2">
      <article class="card" style="background:#fff;"><h3>Official guide style</h3><p><a class="text-link" href="https://www.travelchina.org.cn/en" target="_blank">travelchina.org.cn ↗</a></p></article>
      <article class="card" style="background:#fff;"><h3>Detailed tour style</h3><p><a class="text-link" href="https://www.chinatravel.com/tour/classic-china-tour" target="_blank">chinatravel.com classic tour ↗</a></p></article>
    </div>
    <p class="muted" style="margin-top:10px;">Media note: this V2 page uses publicly reusable assets, not direct copied source images from third-party websites.</p>
  </section>

  <section id="apply" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">Apply</h2>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="Explore China V2 lead" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label for="name">Name</label><input id="name" name="name" required /></div>
      <div class="field"><label for="email">Email</label><input id="email" type="email" name="email" required /></div>
      <div class="field" style="grid-column:1 / -1;"><label for="goal">Goal</label><textarea id="goal" name="goal"></textarea></div>
      <div style="grid-column:1 / -1; display:flex; justify-content:center;"><button class="btn btn-primary" type="submit">Submit</button></div>
    </form>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById('v2-carousel');
      if (!root) return;
      const track = root.querySelector('.carousel-track');
      const slides = Array.from(root.querySelectorAll('.carousel-slide'));
      const prev = root.querySelector('.prev');
      const next = root.querySelector('.next');
      const dotsRoot = document.getElementById('v2-carousel-dots');
      let idx = 0;
      const render = () => {
        track.style.transform = `translateX(-${idx * 100}%)`;
        if (dotsRoot) Array.from(dotsRoot.children).forEach((d, i) => d.classList.toggle('active', i === idx));
      };
      if (dotsRoot) slides.forEach((_, i) => { const b = document.createElement('button'); b.addEventListener('click', () => { idx = i; render(); }); dotsRoot.appendChild(b); });
      prev?.addEventListener('click', () => { idx = (idx - 1 + slides.length) % slides.length; render(); });
      next?.addEventListener('click', () => { idx = (idx + 1) % slides.length; render(); });
      setInterval(() => { idx = (idx + 1) % slides.length; render(); }, 2800);
      render();
    })();
  </script>
</Layout>
